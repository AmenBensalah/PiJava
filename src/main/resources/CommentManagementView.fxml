<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.esportify.controllers.CommentManagementController"
      stylesheets="@post-management.css"
      spacing="18"
      styleClass="pm-root">
    <StackPane styleClass="pm-hero">
        <Region styleClass="pm-hero-overlay"/>
        <HBox alignment="CENTER_LEFT" spacing="24" styleClass="pm-hero-content">
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="COMMENTAIRES" styleClass="pm-kicker"/>
                <Label text="Community Watch" styleClass="pm-title"/>
                <HBox spacing="10">
                    <Label fx:id="heroStatusLabel" text="Flux ouvert" styleClass="pm-chip"/>
                    <Label fx:id="heroCountLabel" text="0 commentaires" styleClass="pm-chip secondary"/>
                </HBox>
            </VBox>
            <HBox spacing="12">
                <Button text="Nouveau commentaire" onAction="#handleCreateComment" styleClass="pm-primary-button"/>
                <Button text="Actualiser" onAction="#handleRefresh" styleClass="pm-ghost-button"/>
            </HBox>
        </HBox>
    </StackPane>

    <FlowPane hgap="16" vgap="16" prefWrapLength="1200">
        <VBox styleClass="pm-stat-card cyan-card" prefWidth="220">
            <Label text="COMMENTAIRES" styleClass="pm-stat-label"/>
            <Label fx:id="totalCommentsLabel" text="0" styleClass="pm-stat-value"/>
            <Label fx:id="commentsDeltaLabel" text="Flux global" styleClass="pm-stat-sub"/>
        </VBox>
        <VBox styleClass="pm-stat-card violet-card" prefWidth="220">
            <Label text="AUTEURS" styleClass="pm-stat-label"/>
            <Label fx:id="activeAuthorsLabel" text="0" styleClass="pm-stat-value"/>
            <Label fx:id="authorsDeltaLabel" text="Voix actives" styleClass="pm-stat-sub"/>
        </VBox>
        <VBox styleClass="pm-stat-card danger-card" prefWidth="220">
            <Label text="POSTS CIBLES" styleClass="pm-stat-label"/>
            <Label fx:id="targetPostsLabel" text="0" styleClass="pm-stat-value"/>
            <Label fx:id="targetsDeltaLabel" text="Publications commentees" styleClass="pm-stat-sub"/>
        </VBox>
    </FlowPane>

    <HBox spacing="18" VBox.vgrow="ALWAYS">
        <VBox styleClass="pm-main-panel" spacing="16" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <TextField fx:id="searchField" promptText="Rechercher contenu, auteur ou post..." styleClass="pm-search-field" HBox.hgrow="ALWAYS"/>
                <Button fx:id="filterAllButton" text="Tous" onAction="#handleFilterAll" styleClass="pm-filter-button active"/>
                <Button fx:id="filterShortButton" text="Courts" onAction="#handleFilterShort" styleClass="pm-filter-button"/>
                <Button fx:id="filterLongButton" text="Longs" onAction="#handleFilterLong" styleClass="pm-filter-button"/>
            </HBox>

            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox styleClass="pm-feed-panel" spacing="14" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Fil commentaires" styleClass="pm-section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="resultCountLabel" text="0 resultats" styleClass="pm-small-chip"/>
                    </HBox>
                    <ListView fx:id="commentsListView" VBox.vgrow="ALWAYS" styleClass="pm-posts-list"/>
                </VBox>

                <VBox styleClass="pm-side-panel" spacing="16" prefWidth="360" minWidth="320" maxWidth="380">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Inspecteur" styleClass="pm-section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="postBadgeLabel" text="POST" styleClass="pm-type-badge"/>
                    </HBox>
                    <VBox spacing="12" styleClass="pm-preview-card">
                        <Label fx:id="selectedTitleLabel" text="Selectionnez un commentaire" styleClass="pm-selected-title"/>
                        <Label fx:id="selectedMetaLabel" text="Auteur - Post" styleClass="pm-selected-meta"/>
                        <Label fx:id="selectedContentLabel" text="Le detail du commentaire apparait ici." wrapText="true" styleClass="pm-selected-content"/>
                    </VBox>
                    <FlowPane hgap="10" vgap="10">
                        <VBox styleClass="pm-mini-card" prefWidth="150">
                            <Label text="Auteur" styleClass="pm-mini-label"/>
                            <Label fx:id="selectedAuthorLabel" text="-" styleClass="pm-mini-value"/>
                        </VBox>
                        <VBox styleClass="pm-mini-card" prefWidth="150">
                            <Label text="Post" styleClass="pm-mini-label"/>
                            <Label fx:id="selectedPostLabel" text="-" styleClass="pm-mini-value"/>
                        </VBox>
                        <VBox styleClass="pm-mini-card" prefWidth="310">
                            <Label text="Date" styleClass="pm-mini-label"/>
                            <Label fx:id="selectedDateLabel" text="-" styleClass="pm-mini-value"/>
                        </VBox>
                    </FlowPane>
                    <VBox spacing="10" styleClass="pm-action-card">
                        <Button text="Ouvrir l'editeur" onAction="#handleEditSelectedComment" maxWidth="Infinity" styleClass="pm-primary-button"/>
                        <Button text="Voir les details" onAction="#handleOpenDetailView" maxWidth="Infinity" styleClass="pm-ghost-button"/>
                        <Button text="Supprimer le commentaire" onAction="#handleDeleteSelectedComment" maxWidth="Infinity" styleClass="pm-danger-button"/>
                    </VBox>
                    <VBox spacing="8" styleClass="pm-activity-card">
                        <Label text="Signal" styleClass="pm-mini-label"/>
                        <Label fx:id="activityStatusLabel" text="Watch pret" styleClass="pm-activity-text"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</VBox>
