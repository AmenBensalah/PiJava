<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0" styleClass="app-root"
            stylesheets="@styles/esportify-theme.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.PROJETPI.AdminDashboardController">
    <left>
        <VBox prefWidth="250.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24.0" left="20.0" right="20.0" top="26.0"/>
            </padding>
            <children>
                <Label styleClass="brand-label" text="E-SPORTIFY"/>
                <Label styleClass="brand-subtitle" text="Admin Dashboard"/>
                <VBox spacing="12.0" styleClass="side-menu">
                    <children>
                        <Label styleClass="menu-heading" text="Administration"/>
                        <Button fx:id="commandesButton" mnemonicParsing="false" onAction="#showCommandes" prefWidth="200.0" styleClass="side-menu-item side-menu-item-active" text="Commandes"/>
                        <Button fx:id="paiementsButton" mnemonicParsing="false" onAction="#showPaiements" prefWidth="200.0" styleClass="side-menu-item" text="Paiements"/>
                        <Button mnemonicParsing="false" onAction="#goToCatalogue" prefWidth="200.0" styleClass="side-menu-item" text="Retour catalogue"/>
                    </children>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <Label styleClass="sidebar-footer" text="Gestion des commandes et paiements"/>
            </children>
        </VBox>
    </left>
    <center>
        <VBox spacing="18.0" styleClass="content-shell">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="top-bar">
                    <children>
                        <Label fx:id="pageTitleLabel" styleClass="page-title" text="Liste des commandes"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false" onAction="#refreshData" prefWidth="160.0" styleClass="ghost-button" text="Actualiser"/>
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="16.0" styleClass="panel-card">
                            <children>
                                <VBox fx:id="commandeFilterCard" spacing="16.0" styleClass="admin-filter-card">
                                    <children>
                                        <HBox spacing="16.0">
                                            <children>
                                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="admin-filter-label" text="Recherche"/>
                                                        <TextField fx:id="searchField" promptText="ID, client, statut, nom..." styleClass="dark-text-field"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="8.0" prefWidth="220.0">
                                                    <children>
                                                        <Label styleClass="admin-filter-label" text="Statut"/>
                                                        <ComboBox fx:id="statutFilterComboBox" prefWidth="220.0" styleClass="dark-text-field"/>
                                                    </children>
                                                </VBox>
                                                <VBox alignment="BOTTOM_LEFT" spacing="8.0">
                                                    <children>
                                                        <Label opacity="0.0" text="."/>
                                                        <HBox spacing="10.0">
                                                            <children>
                                                                <Button mnemonicParsing="false" onAction="#applyCommandFilters" prefWidth="140.0" styleClass="primary-button" text="Rechercher"/>
                                                                <Button mnemonicParsing="false" onAction="#resetCommandFilters" prefWidth="140.0" styleClass="ghost-button" text="Reinitialiser"/>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label styleClass="admin-filter-label" text="Trier"/>
                                                <FlowPane hgap="10.0" vgap="10.0">
                                                    <children>
                                                        <Button fx:id="sortIdDescButton" mnemonicParsing="false" onAction="#sortByIdDesc" styleClass="sort-chip-button" text="ID ↓"/>
                                                        <Button fx:id="sortIdAscButton" mnemonicParsing="false" onAction="#sortByIdAsc" styleClass="sort-chip-button" text="ID ↑"/>
                                                        <Button fx:id="sortMontantDescButton" mnemonicParsing="false" onAction="#sortByMontantDesc" styleClass="sort-chip-button" text="Montant ↓"/>
                                                        <Button fx:id="sortMontantAscButton" mnemonicParsing="false" onAction="#sortByMontantAsc" styleClass="sort-chip-button" text="Montant ↑"/>
                                                        <Button fx:id="sortDateDescButton" mnemonicParsing="false" onAction="#sortByDateDesc" styleClass="sort-chip-button" text="Date ↓"/>
                                                        <Button fx:id="sortDateAscButton" mnemonicParsing="false" onAction="#sortByDateAsc" styleClass="sort-chip-button" text="Date ↑"/>
                                                    </children>
                                                </FlowPane>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="sectionTitleLabel" styleClass="section-title" text="Liste des commandes"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label styleClass="metric-label" text="Total:"/>
                                        <Label fx:id="commandeCountLabel" styleClass="metric-value" text="0"/>
                                    </children>
                                </HBox>
                                <TableView fx:id="commandeTableView" fixedCellSize="44.0" prefHeight="560.0" styleClass="data-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="80.0" text="ID"/>
                                        <TableColumn fx:id="colDate" prefWidth="170.0" text="Date"/>
                                        <TableColumn fx:id="colTotal" prefWidth="130.0" text="Total"/>
                                        <TableColumn fx:id="colClientId" prefWidth="130.0" text="Client ID"/>
                                        <TableColumn fx:id="colStatut" prefWidth="150.0" text="Statut"/>
                                        <TableColumn fx:id="colModifier" prefWidth="150.0" text="Modifier"/>
                                        <TableColumn fx:id="colSupprimer" prefWidth="150.0" text="Supprimer"/>
                                    </columns>
                                </TableView>
                                <TableView fx:id="paymentTableView" fixedCellSize="44.0" prefHeight="560.0" styleClass="data-table" managed="false" visible="false" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="paymentColId" prefWidth="90.0" text="ID"/>
                                        <TableColumn fx:id="paymentColCommandeId" prefWidth="170.0" text="Commande"/>
                                        <TableColumn fx:id="paymentColMontant" prefWidth="180.0" text="Montant"/>
                                        <TableColumn fx:id="paymentColStatut" prefWidth="160.0" text="Statut"/>
                                        <TableColumn fx:id="paymentColDate" prefWidth="190.0" text="Date"/>
                                        <TableColumn fx:id="paymentColActions" prefWidth="150.0" text="Actions"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
