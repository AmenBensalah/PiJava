<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a77.controllers.TournoiUserController"
            styleClass="app-root">

    <left>
        <VBox prefWidth="260.0" styleClass="sidebar">
            <padding>
                <Insets top="20" right="16" bottom="20" left="16"/>
            </padding>
            <Label text="E-SPORTIFY" styleClass="logo-title"/>
            <Label text="USER" styleClass="logo-badge"/>
            <Button text="Retour admin" onAction="#onBackToAdmin" maxWidth="1.7976931348623157E308" styleClass="menu-btn"/>
            <Button text="Rafraichir" onAction="#onRefreshUserData" maxWidth="1.7976931348623157E308" styleClass="menu-btn"/>
            <Button text="Reinitialiser filtres" onAction="#onResetFilters" maxWidth="1.7976931348623157E308" styleClass="menu-btn"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="16.0" styleClass="main-content">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <VBox spacing="12.0" styleClass="header-card">
                <Label text="ESPACE USER" styleClass="header-kicker"/>
                <Label text="DECROCHE TON TOURNOI" styleClass="header-title"/>
                <Label text="Consulte les tournois, rejoins et suis tes participations." styleClass="header-subtitle"/>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <TextField fx:id="tfSearch" promptText="Rechercher un tournoi..." onKeyReleased="#onSearch" styleClass="field-input" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="cbFilterTypeTournoi" promptText="Type tournoi" styleClass="field-input" prefWidth="160"/>
                </HBox>
            </VBox>

            <VBox spacing="14.0" styleClass="section-card">
                <Label text="Tournois disponibles" styleClass="section-title"/>
                <FlowPane fx:id="tournoiCardsPane" hgap="16" vgap="16" prefWrapLength="1100"/>
            </VBox>

            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                <VBox spacing="12.0" styleClass="participation-card" prefWidth="420.0">
                    <Label text="Formulaire de participation" styleClass="section-title"/>
                    <Label text="ID Tournoi" styleClass="field-label"/>
                    <TextField fx:id="tfPartTournoiId" promptText="ID du tournoi" styleClass="field-input" disable="true"/>
                    <Label text="Description" styleClass="field-label"/>
                    <TextField fx:id="tfPartDescription" promptText="Raison de ta participation" styleClass="field-input"/>
                    <Label text="Niveau" styleClass="field-label"/>
                    <ComboBox fx:id="cbPartNiveau" promptText="Selectionner un niveau" styleClass="field-input"/>
                    <HBox spacing="10.0">
                        <Button text="Enregistrer" onAction="#onSaveParticipation" styleClass="primary-btn"/>
                        <Button text="Annuler" onAction="#onCancelParticipationEdit" styleClass="secondary-btn"/>
                    </HBox>
                </VBox>

                <VBox spacing="12.0" styleClass="table-card" VBox.vgrow="ALWAYS">
                    <Label text="Mes participations" styleClass="section-title"/>
                    <TableView fx:id="participationTable" VBox.vgrow="ALWAYS" styleClass="participation-table">
                        <columns>
                            <TableColumn fx:id="colPartId" text="ID" prefWidth="60.0"/>
                            <TableColumn fx:id="colPartTournoiId" text="Tournoi ID" prefWidth="90.0"/>
                            <TableColumn fx:id="colPartTournoiNom" text="Tournoi" prefWidth="170.0"/>
                            <TableColumn fx:id="colPartDescription" text="Description" prefWidth="220.0"/>
                            <TableColumn fx:id="colPartNiveau" text="Niveau" prefWidth="110.0"/>
                            <TableColumn fx:id="colPartActions" text="Actions" prefWidth="140.0"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

            <Label fx:id="userStatusLabel" text="Pret." styleClass="status-label"/>
        </VBox>
    </center>
</BorderPane>
