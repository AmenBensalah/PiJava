<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a77.controllers.RawgGamesController"
            styleClass="app-root">

    <left>
        <VBox prefWidth="250.0" styleClass="sidebar">
            <padding>
                <Insets top="20" right="14" bottom="20" left="14"/>
            </padding>
            <Label text="E-SPORTIFY" styleClass="logo-title"/>
            <Label text="ADMIN" styleClass="logo-badge"/>
            <Button text="Retour Tournois" onAction="#onBackToAdmin" maxWidth="1.7976931348623157E308" styleClass="menu-btn active"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="16.0" styleClass="main-content">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <VBox spacing="10.0" styleClass="header-card">
                <Label text="GAME API" styleClass="header-kicker"/>
                <Label text="RAWG Game Browser" styleClass="header-title"/>
                <Label text="Recherche des jeux et affiche les resultats avec visuels." styleClass="header-subtitle"/>

                <HBox spacing="10.0">
                    <TextField fx:id="tfGameSearch" promptText="Valorant, Counter-Strike, FIFA..." onAction="#onSearchGames" styleClass="field-input" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnSearchGames" text="Rechercher" onAction="#onSearchGames" styleClass="primary-btn"/>
                </HBox>
            </VBox>

            <Label fx:id="gamesStatusLabel" text="Pret." styleClass="status-label"/>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="games-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <FlowPane fx:id="gamesCardsPane" hgap="14" vgap="14" prefWrapLength="1100"/>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
