<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.esportify.controllers.FilActualiteController"
           stylesheets="@styles.css"
           styleClass="app-root">

    <Pane styleClass="background-layer"/>

    <VBox fx:id="backOfficeShell" spacing="0" styleClass="shell-root">
        <StackPane>
            <Pane styleClass="topbar-bg"/>
            <ImageView fitWidth="320" preserveRatio="true" StackPane.alignment="CENTER_RIGHT" translateX="10">
                <image><javafx.scene.image.Image url="@images/dragon.png"/></image>
                <StackPane.margin><Insets right="-8" top="2"/></StackPane.margin>
            </ImageView>
            <HBox styleClass="topbar-content" alignment="CENTER_LEFT">
                <HBox styleClass="topbar-left" alignment="CENTER_LEFT">
                    <ImageView fitWidth="54" fitHeight="54" preserveRatio="true"><image><javafx.scene.image.Image url="@images/logo5.png"/></image></ImageView>
                    <Label text="E-SPORTIFY" styleClass="brand"/>
                    <Label text="ADMIN" styleClass="brand-tag"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField promptText="Rechercher joueurs, equipes, tournois..." styleClass="search-input"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="topbar-right" alignment="CENTER_RIGHT">
                    <Button fx:id="dashboardButton" text="Dashboard" onAction="#handleShowDashboard" styleClass="topbar-action"/>
                    <Button text="Voir mon profil" styleClass="topbar-action"/>
                    <Button fx:id="switchToFrontButton" text="FrontOffice" onAction="#handleShowFrontOffice" styleClass="topbar-action secondary-topbar-action"/>
                </HBox>
            </HBox>
        </StackPane>

        <HBox VBox.vgrow="ALWAYS">
            <VBox fx:id="adminSidebar" styleClass="sidebar sidebar-admin expanded" spacing="0"
                  style="-fx-background-color: linear-gradient(to bottom, #221b57, #3a226e 45%, #26347a 72%, #1b1d4f);">
                <Button fx:id="adminMenuButton" text="Menu" onAction="#handleToggleAdminMenu" styleClass="sidebar-toggle menu-button sidebar-modern" maxWidth="Infinity"/>
                <Separator styleClass="sidebar-separator"/>
                <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                    <HBox styleClass="sidebar-tree-header" maxWidth="Infinity">
                    <Button fx:id="adminFilGroupButton" text="Gestion fil d'actualite" onAction="#handleToggleAdminFilGroup" styleClass="sidebar-item sidebar-modern" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <graphic><Label text="📡" styleClass="sidebar-icon"/></graphic>
                        </Button>
                        <Label fx:id="adminFilChevron" text="▾" styleClass="sidebar-chevron"/>
                    </HBox>
                    <VBox fx:id="adminFilSubmenu" styleClass="sidebar-submenu" spacing="6">
                        <Button fx:id="announcementsButton" text="Gestion des annonces" onAction="#handleShowAnnouncements" styleClass="sidebar-item sidebar-sub sidebar-modern" maxWidth="Infinity">
                            <graphic><Label text="📣" styleClass="sidebar-icon sub-icon"/></graphic>
                        </Button>
                        <Button fx:id="postsButton" text="Gestion des publications" onAction="#handleShowPosts" styleClass="sidebar-item sidebar-sub active sidebar-modern" maxWidth="Infinity">
                            <graphic><Label text="✎" styleClass="sidebar-icon sub-icon"/></graphic>
                        </Button>
                        <Button fx:id="commentsButton" text="Gestion des commentaires" onAction="#handleShowComments" styleClass="sidebar-item sidebar-sub sidebar-modern" maxWidth="Infinity">
                            <graphic><Label text="💬" styleClass="sidebar-icon sub-icon"/></graphic>
                        </Button>
                        <Button fx:id="aiButton" text="Centre IA" onAction="#handleShowAi" styleClass="sidebar-item sidebar-sub sidebar-modern" maxWidth="Infinity">
                            <graphic><Label text="🧠" styleClass="sidebar-icon sub-icon"/></graphic>
                        </Button>
                    </VBox>
                    <Separator styleClass="sidebar-separator"/>
                    <Button fx:id="adminEquipesButton" text="Gestion Equipes" onAction="#handleAdminEquipes" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="👥" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="adminTournoiButton" text="Gestion Tournoi" onAction="#handleAdminTournoi" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="🏆" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="adminBoutiqueButton" text="Gestion Boutique" onAction="#handleAdminBoutique" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="🛍" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="adminComptesButton" text="Gestion comptes" onAction="#handleAdminComptes" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="👤" styleClass="sidebar-icon"/></graphic>
                    </Button>
                </VBox>
                <VBox styleClass="sidebar-footer" spacing="14">
                    <Button text="◐" styleClass="theme-toggle-btn moon-button" maxWidth="Infinity"/>
                    <Button text="Deconnexion" styleClass="sidebar-logout" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" pannable="true" styleClass="content-scroll" HBox.hgrow="ALWAYS">
                <content>
                    <VBox styleClass="content-wrap" alignment="TOP_CENTER">
                        <StackPane fx:id="backContentStack" styleClass="content page-root" StackPane.alignment="TOP_CENTER">
                            <VBox fx:id="dashboardView" spacing="18" styleClass="content-shell page-frame">
                                <StackPane styleClass="admin-hero-card">
                                    <VBox spacing="8" styleClass="admin-hero-inner">
                                        <Label text="COMMAND CENTER" styleClass="admin-hero-title"/>
                                        <Label text="Vue globale du backoffice, performances et activite en temps reel." styleClass="admin-hero-subtitle"/>
                                    </VBox>
                                </StackPane>
                                <HBox spacing="14" styleClass="metrics-row">
                                    <VBox styleClass="dashboard-metric" HBox.hgrow="ALWAYS"><Label text="UTILISATEURS" styleClass="dashboard-kicker"/><Label fx:id="totalPostsLabel" text="0" styleClass="dashboard-value"/><Label text="Plateforme" styleClass="dashboard-caption"/></VBox>
                                    <VBox styleClass="dashboard-metric" HBox.hgrow="ALWAYS"><Label text="EQUIPES" styleClass="dashboard-kicker"/><Label fx:id="eventsLabel" text="0" styleClass="dashboard-value"/><Label text="Communautes" styleClass="dashboard-caption"/></VBox>
                                    <VBox styleClass="dashboard-metric" HBox.hgrow="ALWAYS"><Label text="POSTS / MEDIA" styleClass="dashboard-kicker"/><Label fx:id="mediaLabel" text="0" styleClass="dashboard-value"/><Label text="Fil d'actualite" styleClass="dashboard-caption"/></VBox>
                                </HBox>
                                <VBox styleClass="dashboard-chart-card" VBox.vgrow="ALWAYS">
                                    <Label text="Activite mensuelle" styleClass="panel-title"/>
                                    <Label fx:id="latestPostLabel" text="Derniere publication" wrapText="true" styleClass="panel-text"/>
                                    <Pane VBox.vgrow="ALWAYS" styleClass="fake-chart"/>
                                </VBox>
                            </VBox>

                            <VBox fx:id="postsView" spacing="18" styleClass="content-shell page-frame" visible="false" managed="false">
                                <StackPane styleClass="admin-page-hero">
                                    <VBox spacing="8" styleClass="admin-page-hero-inner">
                                        <Label text="FIL D'ACTUALITE" styleClass="admin-page-kicker"/>
                                        <Label text="GESTION DES PUBLICATIONS" styleClass="admin-page-title"/>
                                        <Label text="Moderez et mettez en avant les publications." styleClass="admin-page-lead"/>
                                        <HBox spacing="14"><Button text="Creer une publication" onAction="#handleAdd" styleClass="hero-button primary"/><Button text="Rafraichir" onAction="#handleRefresh" styleClass="hero-button ghost"/></HBox>
                                    </VBox>
                                </StackPane>
                                <HBox spacing="12" styleClass="admin-tabs-row">
                                    <Button text="Publications" onAction="#handleShowPosts" styleClass="admin-tab active"/>
                                    <Button text="Annonces" onAction="#handleShowAnnouncements" styleClass="admin-tab"/>
                                    <Button text="Commentaires" onAction="#handleShowComments" styleClass="admin-tab"/>
                                    <Button text="Centre IA" onAction="#handleShowAi" styleClass="admin-tab"/>
                                </HBox>
                                <VBox styleClass="search-panel" spacing="14">
                                    <Label text="Recherche avancee" styleClass="search-panel-title"/>
                                    <HBox spacing="14" styleClass="filters-grid">
                                        <VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="CONTENU" styleClass="field-label"/><TextField fx:id="searchField" promptText="Rechercher..." styleClass="search-field"/></VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="TYPE" styleClass="field-label"/><ComboBox promptText="-- Tous --" styleClass="search-combo"/></VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="DATE (DU)" styleClass="field-label"/><TextField promptText="jj / mm / aaaa" styleClass="search-field"/></VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="DATE (AU)" styleClass="field-label"/><TextField promptText="jj / mm / aaaa" styleClass="search-field"/></VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS"><Label text="PAR PAGE" styleClass="field-label"/><ComboBox promptText="10" styleClass="search-combo"/></VBox>
                                    </HBox>
                                    <HBox spacing="12"><Button text="Rechercher" onAction="#handleSearch" styleClass="filter-action-btn primary"/><Button text="Reinitialiser" onAction="#handleRefresh" styleClass="filter-action-btn ghost"/></HBox>
                                    <HBox spacing="12" styleClass="sort-row"><Label text="Trier :" styleClass="panel-text"/><Button text="Date ?" styleClass="sort-pill"/><Button text="Date ?" styleClass="sort-pill"/><Button text="Type A?Z" styleClass="sort-pill"/><Button text="Type Z?A" styleClass="sort-pill"/></HBox>
                                </VBox>
                                <HBox spacing="18" VBox.vgrow="ALWAYS" styleClass="responsive-split">
                                    <VBox styleClass="form-panel" spacing="14" prefWidth="410" maxWidth="410">
                                        <Label text="FORMULAIRE PUBLICATION" styleClass="form-panel-title"/>
                                        <TextArea fx:id="contentArea" promptText="Contenu de la publication" wrapText="true" prefRowCount="5" styleClass="form-input area"/>
                                        <TextField fx:id="imageField" promptText="Image (/uploads/... ou URL)" styleClass="form-input"/>
                                        <TextField fx:id="videoField" promptText="Video (https://...)" styleClass="form-input"/>
                                        <CheckBox fx:id="eventCheckBox" text="Publication evenement" styleClass="form-check"/>
                                        <TextField fx:id="eventTitleField" promptText="Titre evenement" styleClass="form-input"/>
                                        <HBox spacing="12"><TextField fx:id="eventDateField" promptText="AAAA-MM-JJ" styleClass="form-input" HBox.hgrow="ALWAYS"/><TextField fx:id="eventLocationField" promptText="Lieu" styleClass="form-input" HBox.hgrow="ALWAYS"/></HBox>
                                        <HBox spacing="12"><TextField fx:id="maxParticipantsField" promptText="Places" styleClass="form-input" HBox.hgrow="ALWAYS"/><TextField fx:id="authorIdField" promptText="Auteur ID" styleClass="form-input" HBox.hgrow="ALWAYS"/></HBox>
                                        <HBox spacing="10"><Button text="Ajouter" onAction="#handleAdd" styleClass="hero-button primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Button text="Modifier" onAction="#handleUpdate" styleClass="hero-button ghost" HBox.hgrow="ALWAYS" maxWidth="Infinity"/><Button text="Supprimer" onAction="#handleDelete" styleClass="danger-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/></HBox>
                                        <Label fx:id="statusLabel" text="Pret" wrapText="true" styleClass="status-label"/>
                                    </VBox>
                                    <VBox styleClass="table-panel" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                        <TableView fx:id="postsTable" VBox.vgrow="ALWAYS" styleClass="posts-table">
                                            <columns>
                                                <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                                                <TableColumn fx:id="mediaColumn" text="TYPE" prefWidth="120"/>
                                                <TableColumn fx:id="contentColumn" text="CONTENU" prefWidth="280"/>
                                                <TableColumn fx:id="eventColumn" text="CATEGORIE" prefWidth="170"/>
                                                <TableColumn fx:id="authorColumn" text="MEDIA" prefWidth="120"/>
                                                <TableColumn fx:id="createdAtColumn" text="CREATION" prefWidth="150"/>
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox fx:id="announcementsView" spacing="18" styleClass="content-shell page-frame" visible="false" managed="false">
                                <StackPane styleClass="admin-page-hero"><VBox spacing="8" styleClass="admin-page-hero-inner"><Label text="FIL D'ACTUALITE" styleClass="admin-page-kicker"/><Label text="GESTION DES ANNONCES" styleClass="admin-page-title"/><Label text="Creez et suivez les annonces du fil d'actualite." styleClass="admin-page-lead"/></VBox></StackPane>
                                <HBox spacing="12" styleClass="admin-tabs-row"><Button text="Publications" onAction="#handleShowPosts" styleClass="admin-tab"/><Button text="Annonces" onAction="#handleShowAnnouncements" styleClass="admin-tab active"/><Button text="Commentaires" onAction="#handleShowComments" styleClass="admin-tab"/><Button text="Centre IA" onAction="#handleShowAi" styleClass="admin-tab"/></HBox>
                                <VBox styleClass="search-panel"><Label text="Recherche avancee" styleClass="search-panel-title"/></VBox>
                                <HBox spacing="18" VBox.vgrow="ALWAYS" styleClass="responsive-split">
                                    <VBox styleClass="form-panel" spacing="14" prefWidth="410" maxWidth="410">
                                        <Label text="FORMULAIRE ANNONCE" styleClass="form-panel-title"/>
                                        <TextField fx:id="announcementTitleField" promptText="Titre" styleClass="form-input"/>
                                        <TextField fx:id="announcementTagField" promptText="Tag" styleClass="form-input"/>
                                        <TextField fx:id="announcementLinkField" promptText="Lien (https://...)" styleClass="form-input"/>
                                        <TextField fx:id="announcementMediaTypeField" promptText="Media type (text/image/video)" styleClass="form-input"/>
                                        <TextField fx:id="announcementMediaFilenameField" promptText="Media filename" styleClass="form-input"/>
                                        <TextArea fx:id="announcementContentArea" promptText="Contenu" wrapText="true" prefRowCount="4" styleClass="form-input area"/>
                                        <HBox spacing="10">
                                            <Button text="Ajouter" onAction="#handleAnnouncementAdd" styleClass="hero-button primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                            <Button text="Modifier" onAction="#handleAnnouncementUpdate" styleClass="hero-button ghost" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                            <Button text="Supprimer" onAction="#handleAnnouncementDelete" styleClass="danger-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        </HBox>
                                    </VBox>
                                    <VBox styleClass="table-panel" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                        <TableView fx:id="announcementsTable" VBox.vgrow="ALWAYS" styleClass="posts-table">
                                            <columns>
                                                <TableColumn fx:id="announcementIdColumn" text="ID" prefWidth="70"/>
                                                <TableColumn fx:id="announcementTagColumn" text="TAG" prefWidth="120"/>
                                                <TableColumn fx:id="announcementTitleColumn" text="TITRE" prefWidth="220"/>
                                                <TableColumn fx:id="announcementLinkColumn" text="LIEN" prefWidth="240"/>
                                                <TableColumn fx:id="announcementCreatedAtColumn" text="CREATION" prefWidth="150"/>
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox fx:id="commentsView" spacing="18" styleClass="content-shell page-frame" visible="false" managed="false">
                                <StackPane styleClass="admin-page-hero"><VBox spacing="8" styleClass="admin-page-hero-inner"><Label text="FIL D'ACTUALITE" styleClass="admin-page-kicker"/><Label text="GESTION DES COMMENTAIRES" styleClass="admin-page-title"/></VBox></StackPane>
                                <HBox spacing="12" styleClass="admin-tabs-row"><Button text="Publications" onAction="#handleShowPosts" styleClass="admin-tab"/><Button text="Annonces" onAction="#handleShowAnnouncements" styleClass="admin-tab"/><Button text="Commentaires" onAction="#handleShowComments" styleClass="admin-tab active"/><Button text="Centre IA" onAction="#handleShowAi" styleClass="admin-tab"/></HBox>
                                <VBox styleClass="search-panel"><Label text="Recherche avancee" styleClass="search-panel-title"/></VBox>
                                <HBox spacing="18" VBox.vgrow="ALWAYS" styleClass="responsive-split">
                                    <VBox styleClass="form-panel" spacing="14" prefWidth="410" maxWidth="410">
                                        <Label text="FORMULAIRE COMMENTAIRE" styleClass="form-panel-title"/>
                                        <TextArea fx:id="commentContentArea" promptText="Commentaire" wrapText="true" prefRowCount="4" styleClass="form-input area"/>
                                        <TextField fx:id="commentAuthorIdField" promptText="Auteur ID" styleClass="form-input"/>
                                        <TextField fx:id="commentPostIdField" promptText="Publication ID" styleClass="form-input"/>
                                        <HBox spacing="10">
                                            <Button text="Ajouter" onAction="#handleCommentAdd" styleClass="hero-button primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                            <Button text="Modifier" onAction="#handleCommentUpdate" styleClass="hero-button ghost" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                            <Button text="Supprimer" onAction="#handleCommentDelete" styleClass="danger-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        </HBox>
                                    </VBox>
                                    <VBox styleClass="table-panel" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                        <TableView fx:id="commentsTable" VBox.vgrow="ALWAYS" styleClass="posts-table">
                                            <columns>
                                                <TableColumn fx:id="commentIdColumn" text="ID" prefWidth="70"/>
                                                <TableColumn fx:id="commentAuthorColumn" text="AUTEUR" prefWidth="120"/>
                                                <TableColumn fx:id="commentPostColumn" text="POST" prefWidth="90"/>
                                                <TableColumn fx:id="commentContentColumn" text="COMMENTAIRE" prefWidth="260"/>
                                                <TableColumn fx:id="commentCreatedAtColumn" text="CREATION" prefWidth="150"/>
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox fx:id="aiView" spacing="18" styleClass="content-shell page-frame" visible="false" managed="false">
                                <StackPane styleClass="admin-page-hero"><VBox spacing="8" styleClass="admin-page-hero-inner"><Label text="FIL D'ACTUALITE" styleClass="admin-page-kicker"/><Label text="CENTRE IA" styleClass="admin-page-title"/></VBox></StackPane>
                            </VBox>
                        </StackPane>
                    </VBox>
                </content>
            </ScrollPane>
        </HBox>
    </VBox>

    <VBox fx:id="frontOfficeShell" spacing="0" styleClass="shell-root" visible="false" managed="false">
        <StackPane>
            <Pane styleClass="topbar-bg"/>
            <ImageView fitWidth="320" preserveRatio="true" StackPane.alignment="CENTER_RIGHT" translateX="10">
                <image><javafx.scene.image.Image url="@images/dragon.png"/></image>
                <StackPane.margin><Insets right="-8" top="2"/></StackPane.margin>
            </ImageView>
            <HBox styleClass="topbar-content" alignment="CENTER_LEFT">
                <HBox styleClass="topbar-left" alignment="CENTER_LEFT">
                    <ImageView fitWidth="54" fitHeight="54" preserveRatio="true"><image><javafx.scene.image.Image url="@images/logo5.png"/></image></ImageView>
                    <Label text="E-SPORTIFY" styleClass="brand"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField promptText="Rechercher joueurs, equipes, tournois..." styleClass="search-input"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="topbar-right" alignment="CENTER_RIGHT" spacing="12">
                    <Button text="Notifications" styleClass="icon-btn"/>
                    <Button text="Messages" styleClass="icon-btn"/>
                    <Button text="Parametres" styleClass="icon-btn"/>
                    <Button text="Admin" onAction="#handleShowBackOffice" styleClass="topbar-action secondary-topbar-action"/>
                </HBox>
            </HBox>
        </StackPane>

        <HBox VBox.vgrow="ALWAYS">
            <VBox fx:id="frontSidebar" styleClass="sidebar sidebar-front expanded" spacing="0"
                  style="-fx-background-color: linear-gradient(to bottom, #221b57, #3a226e 45%, #26347a 72%, #1b1d4f);">
                <Button fx:id="frontMenuButton" text="Menu" onAction="#handleToggleFrontMenu" styleClass="sidebar-toggle menu-button sidebar-modern" maxWidth="Infinity"/>
                <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                    <Button fx:id="frontFeedButton" text="Fil d'actualite" onAction="#handleShowFrontFeed" styleClass="sidebar-item active sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="📰" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="frontEquipesButton" text="Equipes" onAction="#handleFrontEquipes" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="👥" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="frontTournoisButton" text="Tournois" onAction="#handleFrontTournois" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="🏆" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="frontBoutiqueButton" text="Boutique" onAction="#handleFrontBoutique" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="🛍" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="frontCommandesButton" text="Commandes" onAction="#handleFrontCommandes" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="👜" styleClass="sidebar-icon"/></graphic>
                    </Button>
                    <Button fx:id="frontProfileButton" text="Profil" onAction="#handleShowFrontProfile" styleClass="sidebar-item sidebar-modern" maxWidth="Infinity">
                        <graphic><Label text="👤" styleClass="sidebar-icon"/></graphic>
                    </Button>
                </VBox>
                <VBox styleClass="sidebar-footer" spacing="14">
                    <Button text="◐" styleClass="theme-toggle-btn moon-button" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" pannable="true" styleClass="content-scroll" HBox.hgrow="ALWAYS">
                <content>
                    <VBox styleClass="content-wrap" alignment="TOP_CENTER">
                        <StackPane fx:id="frontContentStack" styleClass="content page-root" StackPane.alignment="TOP_CENTER">
                            <VBox fx:id="frontFeedView" spacing="18" styleClass="content-shell page-frame" VBox.vgrow="ALWAYS">
                                <HBox styleClass="feed-layout front-layout" spacing="22">
                                    <VBox styleClass="feed-main" spacing="18" HBox.hgrow="ALWAYS">
                                        <Label text="Fil d'actualite" styleClass="front-page-title"/>
                                        <VBox styleClass="composer-card" spacing="18">
                                            <HBox styleClass="composer-header" alignment="CENTER_LEFT" spacing="14">
                                                <StackPane styleClass="avatar"><Label text="A" styleClass="avatar-text"/></StackPane>
                                                <Label text="Vous" styleClass="composer-user"/>
                                            </HBox>
                                            <TextArea fx:id="frontContentArea" promptText="Publier un message, une image ou un lien video..." wrapText="true" prefRowCount="3" styleClass="composer-input"/>
                                            <HBox spacing="10"><Button text="Images/Videos/Jeux" styleClass="chip-btn"/><TextField fx:id="frontImageField" promptText="Lien image" styleClass="mini-input" HBox.hgrow="ALWAYS"/></HBox>
                                            <HBox spacing="10"><Button text="Lien video" styleClass="chip-btn"/><TextField fx:id="frontVideoField" promptText="https://..." styleClass="mini-input" HBox.hgrow="ALWAYS"/><CheckBox fx:id="frontEventCheckBox" text="EVENT" styleClass="chip-check"/></HBox>
                                            <HBox spacing="10"><TextField fx:id="frontEventTitleField" promptText="Titre evenement" styleClass="mini-input" HBox.hgrow="ALWAYS"/><TextField fx:id="frontEventDateField" promptText="AAAA-MM-JJ" styleClass="mini-input date-input"/></HBox>
                                            <HBox spacing="10"><TextField fx:id="frontEventLocationField" promptText="Lieu / lien" styleClass="mini-input" HBox.hgrow="ALWAYS"/><TextField fx:id="frontMaxParticipantsField" promptText="Places" styleClass="mini-input short-input"/><TextField fx:id="frontAuthorIdField" promptText="Auteur ID" styleClass="mini-input short-input"/></HBox>
                                            <HBox styleClass="composer-actions" alignment="CENTER_LEFT" spacing="10">
                                                <Button text="Orthographe" styleClass="chip-btn"/>
                                                <Button text="Ton pro" styleClass="chip-btn"/>
                                                <Button text="Version courte" styleClass="chip-btn"/>
                                                <Button text="Version longue" styleClass="chip-btn"/>
                                                <Button text="Hashtags IA" styleClass="chip-btn"/>
                                                <Button text="Analyse IA" styleClass="chip-btn"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button text="Publier" onAction="#handleFrontPublish" styleClass="publish-btn"/>
                                            </HBox>
                                        </VBox>
                                        <HBox spacing="12" styleClass="filters-bar"><Button fx:id="filterAllButton" text="Tout" onAction="#handleFilterAll" styleClass="filter-pill"/><Button fx:id="filterTeamsButton" text="Equipes" onAction="#handleFilterTeams" styleClass="filter-pill"/><Button fx:id="filterPlayersButton" text="Joueurs" onAction="#handleFilterPlayers" styleClass="filter-pill"/><Button fx:id="filterTournamentsButton" text="Tournois" onAction="#handleFilterTournaments" styleClass="filter-pill"/><Button fx:id="filterMediaButton" text="Media" onAction="#handleFilterMedia" styleClass="filter-pill"/></HBox>
                                        <VBox fx:id="frontFeedBox" VBox.vgrow="ALWAYS" styleClass="front-feed-list" spacing="16"/>
                                    </VBox>
                                    <VBox styleClass="feed-right" spacing="18" prefWidth="300" minWidth="240" maxWidth="320">
                                        <VBox styleClass="side-panel">
                                            <Label text="Annonces officielles" styleClass="side-title"/>
                                            <VBox fx:id="frontAnnouncementsBox" VBox.vgrow="ALWAYS" styleClass="front-feed-list" spacing="12"/>
                                        </VBox>
                                        <VBox styleClass="side-panel compact"><Label text="Best time to post" styleClass="side-title"/><VBox styleClass="side-inner-card"><Label text="Heure ideale: 01:00" styleClass="side-main-number"/><Label text="Heure estimee selon les pics d'engagement recents de votre audience." wrapText="true" styleClass="panel-text"/></VBox></VBox>
                                        <VBox styleClass="side-panel"><Label text="Tendances" styleClass="side-title"/><HBox styleClass="trend-row"><Label text="#sport" styleClass="trend-text"/><Label text="8" styleClass="trend-badge"/></HBox><HBox styleClass="trend-row"><Label text="#lectronique" styleClass="trend-text"/><Label text="5" styleClass="trend-badge"/></HBox><HBox styleClass="trend-row"><Label text="#test" styleClass="trend-text"/><Label text="4" styleClass="trend-badge"/></HBox><HBox styleClass="trend-row"><Label text="#tournoi" styleClass="trend-text"/><Label text="4" styleClass="trend-badge"/></HBox><HBox styleClass="trend-row"><Label text="#exemple" styleClass="trend-text"/><Label text="4" styleClass="trend-badge"/></HBox></VBox>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox fx:id="frontSavedView" spacing="18" styleClass="content-shell page-frame" visible="false" managed="false"><Label text="Commandes" styleClass="front-page-title"/><VBox styleClass="side-panel"><ListView fx:id="frontSavedList" VBox.vgrow="ALWAYS" styleClass="simple-list"/></VBox></VBox>
                            <VBox fx:id="frontProfileView" spacing="18" styleClass="content-shell page-frame" visible="false" managed="false"><Label text="Profil" styleClass="front-page-title"/><VBox styleClass="side-panel"><ListView fx:id="frontProfileList" VBox.vgrow="ALWAYS" styleClass="simple-list"/></VBox></VBox>
                        </StackPane>
                    </VBox>
                </content>
            </ScrollPane>
        </HBox>
    </VBox>
</StackPane>
