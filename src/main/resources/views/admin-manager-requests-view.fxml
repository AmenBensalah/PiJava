<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.AdminManagerRequestsController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            stylesheets="@../ajoutProduit.css"
            styleClass="page-scroll transparent-scroll-pane">
    <content>
        <VBox spacing="25.0" styleClass="main-area-bg" minHeight="960.0">
            <children>
                <HBox prefHeight="140.0" styleClass="boutique-banner" alignment="CENTER_LEFT">
                    <padding><Insets left="34.0" right="34.0" /></padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #00e5ff; -fx-font-size: 11px; -fx-font-weight: bold;" text="ADMIN" />
                            <Label styleClass="banner-title" text="GESTION DES DEMANDES MANAGER" />
                            <Label styleClass="banner-subtitle" text="Consultez, acceptez, refusez ou supprimez les demandes manager dans ce meme design admin." wrapText="true" />
                        </VBox>
                        <HBox spacing="14.0" alignment="CENTER_RIGHT">
                            <Button fx:id="refreshButton" onAction="#onRefresh" text="Rafraichir" styleClass="btn-secondary" prefWidth="130.0" prefHeight="45.0" />
                        </HBox>
                    </children>
                </HBox>

                <HBox spacing="12.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Validation manager" styleClass="cat-pill cat-pill-active" />
                        <Label text="Recherche rapide" styleClass="cat-pill" />
                        <Label text="Actions directes" styleClass="cat-pill" />
                    </children>
                </HBox>

                <VBox fx:id="searchShell" styleClass="advanced-search-box" spacing="15.0">
                    <padding><Insets top="20.0" right="25.0" bottom="20.0" left="25.0"/></padding>
                    <children>
                        <Label text="Recherche avancee" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                        <GridPane hgap="18.0" vgap="14.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="42.0" />
                                <ColumnConstraints percentWidth="24.0" />
                                <ColumnConstraints percentWidth="34.0" />
                            </columnConstraints>
                            <children>
                                <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="UTILISATEUR / EMAIL / NIVEAU" styleClass="filter-label" />
                                        <TextField fx:id="keywordField" promptText="Utilisateur, email, niveau ou motivation" styleClass="filter-input" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="STATUT" styleClass="filter-label" />
                                        <ComboBox fx:id="statusFilterBox" maxWidth="1.7976931348623157E308" styleClass="filter-input" />
                                    </children>
                                </VBox>
                                <HBox spacing="12.0" alignment="BOTTOM_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Button fx:id="searchButton" onAction="#onSearch" text="Rechercher" styleClass="btn-rechercher" prefWidth="140.0" prefHeight="45.0" />
                                        <Button fx:id="resetButton" onAction="#onResetFilters" text="Reinitialiser" styleClass="btn-reinitialiser" prefWidth="150.0" prefHeight="45.0" />
                                    </children>
                                </HBox>
                            </children>
                        </GridPane>
                        <HBox spacing="14.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Trier :" styleClass="side-label" />
                                <Button fx:id="sortDateDescButton" onAction="#onSortDateDesc" text="Date desc" styleClass="sort-pill" />
                                <Button fx:id="sortDateAscButton" onAction="#onSortDateAsc" text="Date asc" styleClass="sort-pill" />
                                <Button fx:id="sortIdDescButton" onAction="#onSortIdDesc" text="ID desc" styleClass="sort-pill" />
                                <Button fx:id="sortIdAscButton" onAction="#onSortIdAsc" text="ID asc" styleClass="sort-pill" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox fx:id="tableToolbar" styleClass="filter-panel" spacing="14.0">
                    <padding><Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Registre des demandes manager" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;" />
                                        <Label text="Validez les profils et mettez a jour le role manager depuis cette meme table." style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="infoLabel" text="Chargement des demandes..." style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
                            </children>
                        </HBox>

                        <TableView fx:id="requestsTable" minHeight="460.0" styleClass="admin-reference-table admin-teams-table">
                            <columns>
                                <TableColumn fx:id="idColumn" prefWidth="86" text="ID"/>
                                <TableColumn fx:id="usernameColumn" prefWidth="220" text="UTILISATEUR"/>
                                <TableColumn fx:id="emailColumn" prefWidth="270" text="EMAIL"/>
                                <TableColumn fx:id="niveauColumn" prefWidth="140" text="NIVEAU"/>
                                <TableColumn fx:id="motivationColumn" prefWidth="420" text="MOTIVATION"/>
                                <TableColumn fx:id="statusColumn" prefWidth="126" text="STATUT"/>
                                <TableColumn fx:id="dateColumn" prefWidth="170" text="DATE"/>
                                <TableColumn fx:id="actionsColumn" prefWidth="260" text="ACTIONS"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
            <padding><Insets bottom="40.0" left="34.0" right="34.0" top="26.0" /></padding>
        </VBox>
    </content>
</ScrollPane>
