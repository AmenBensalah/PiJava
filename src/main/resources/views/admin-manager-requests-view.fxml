<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.AdminManagerRequestsController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page admin-reference-page">
            <children>
                <VBox spacing="12" styleClass="hero-card admin-reference-hero">
                    <children>
                        <Label text="ADMIN" styleClass="admin-eyebrow"/>
                        <Label text="DEMANDES DE MANAGER" styleClass="admin-reference-title"/>
                        <Label text="Consultez les demandes envoyees par les utilisateurs avec le meme affichage premium que la liste des equipes." styleClass="admin-reference-subtitle" wrapText="true"/>
                    </children>
                </VBox>

                <HBox spacing="14">
                    <children>
                        <Label text="Vue premium" styleClass="admin-filter-pill is-active"/>
                        <Label text="Demandes centralisees" styleClass="admin-filter-pill"/>
                        <Label text="Suppression rapide" styleClass="admin-filter-pill"/>
                    </children>
                </HBox>

                <VBox fx:id="searchShell" spacing="16" styleClass="admin-search-shell admin-premium-search-shell">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4">
                                    <children>
                                        <Label text="Recherche avancee" styleClass="admin-search-title"/>
                                        <Label text="Filtrez rapidement par utilisateur, niveau, email ou statut." styleClass="admin-reference-subtitle"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <GridPane hgap="14" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="42"/>
                                <ColumnConstraints percentWidth="26"/>
                                <ColumnConstraints percentWidth="32"/>
                            </columnConstraints>
                            <children>
                                <TextField fx:id="keywordField" promptText="Utilisateur, email, niveau ou motivation" styleClass="field admin-search-field admin-elevated-field" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="statusFilterBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo admin-search-field admin-elevated-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <HBox spacing="12" styleClass="admin-search-actions" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Button fx:id="searchButton" text="Rechercher" onAction="#onSearch" styleClass="admin-glow-button"/>
                                        <Button fx:id="resetButton" text="Reinitialiser" onAction="#onResetFilters" styleClass="admin-ghost-button"/>
                                        <Button fx:id="refreshButton" text="Rafraichir" onAction="#onRefresh" styleClass="admin-ghost-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </GridPane>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Trier :" styleClass="muted-label"/>
                                <Button fx:id="sortDateDescButton" text="Date desc" onAction="#onSortDateDesc" styleClass="admin-sort-pill admin-sort-button"/>
                                <Button fx:id="sortDateAscButton" text="Date asc" onAction="#onSortDateAsc" styleClass="admin-sort-pill admin-sort-button"/>
                                <Button fx:id="sortIdDescButton" text="ID desc" onAction="#onSortIdDesc" styleClass="admin-sort-pill admin-sort-button"/>
                                <Button fx:id="sortIdAscButton" text="ID asc" onAction="#onSortIdAsc" styleClass="admin-sort-pill admin-sort-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox fx:id="tableToolbar" alignment="CENTER_LEFT" spacing="14" styleClass="admin-table-toolbar">
                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Registre des demandes manager" styleClass="admin-search-title"/>
                                <Label text="Accepter et Refuser restent statiques. Supprimer retire vraiment la demande." styleClass="admin-reference-subtitle"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="infoLabel" text="Chargement des demandes..." styleClass="muted-label"/>
                    </children>
                </HBox>

                <TableView fx:id="requestsTable" minHeight="420" styleClass="manager-table admin-reference-table admin-teams-table">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="86" text="ID"/>
                        <TableColumn fx:id="usernameColumn" prefWidth="220" text="UTILISATEUR"/>
                        <TableColumn fx:id="emailColumn" prefWidth="270" text="EMAIL"/>
                        <TableColumn fx:id="niveauColumn" prefWidth="140" text="NIVEAU"/>
                        <TableColumn fx:id="motivationColumn" prefWidth="420" text="MOTIVATION"/>
                        <TableColumn fx:id="statusColumn" prefWidth="126" text="STATUT"/>
                        <TableColumn fx:id="dateColumn" prefWidth="170" text="DATE"/>
                        <TableColumn fx:id="actionsColumn" prefWidth="260" text="ACTIONS"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER" spacing="10" styleClass="admin-pagination-shell">
                    <children>
                        <Button text="&lt;" styleClass="admin-page-button"/>
                        <Button text="1" styleClass="admin-page-button active"/>
                        <Button text="2" styleClass="admin-page-button"/>
                        <Button text="&gt;" styleClass="admin-page-button"/>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="26" right="28" bottom="32" left="28"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
