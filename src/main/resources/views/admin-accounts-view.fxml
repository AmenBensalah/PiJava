<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.AdminAccountsController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page admin-reference-page">
            <children>
                <VBox spacing="12" styleClass="hero-card admin-reference-hero">
                    <children>
                        <Label text="ADMIN" styleClass="admin-eyebrow"/>
                        <Label text="GESTION DES COMPTES" styleClass="admin-reference-title"/>
                        <Label text="Tableau simple des utilisateurs avec actions de gestion et changement de role." styleClass="admin-reference-subtitle" wrapText="true"/>
                    </children>
                </VBox>

                <VBox fx:id="searchShell" spacing="16" styleClass="admin-search-shell admin-premium-search-shell">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <children>
                                <TextField fx:id="keywordField" promptText="Rechercher par username, email, role..." HBox.hgrow="ALWAYS" styleClass="field admin-search-field admin-elevated-field"/>
                                <Button fx:id="searchButton" text="Rechercher" onAction="#onSearch" styleClass="admin-glow-button"/>
                                <Button fx:id="resetButton" text="Reinitialiser" onAction="#onResetFilters" styleClass="admin-ghost-button"/>
                                <Button fx:id="refreshButton" text="Actualiser" onAction="#onRefresh" styleClass="admin-ghost-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox fx:id="tableToolbar" alignment="CENTER_LEFT" spacing="14" styleClass="admin-table-toolbar">
                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Registre des utilisateurs" styleClass="admin-search-title"/>
                                <Label text="Utilisateurs, roles, statuts et actions rapides." styleClass="admin-reference-subtitle"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </children>
                </HBox>

                <TableView fx:id="usersTable" minHeight="460" styleClass="manager-table admin-reference-table admin-teams-table">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="80" text="ID"/>
                        <TableColumn fx:id="usernameColumn" prefWidth="210" text="USERNAME"/>
                        <TableColumn fx:id="firstNameColumn" prefWidth="160" text="PRENOM"/>
                        <TableColumn fx:id="emailColumn" prefWidth="260" text="EMAIL"/>
                        <TableColumn fx:id="phoneColumn" prefWidth="150" text="TELEPHONE"/>
                        <TableColumn fx:id="roleColumn" prefWidth="120" text="ROLE"/>
                        <TableColumn fx:id="statusColumn" prefWidth="120" text="STATUT"/>
                        <TableColumn fx:id="createdAtColumn" prefWidth="170" text="CREE LE"/>
                        <TableColumn fx:id="actionsColumn" prefWidth="470" text="ACTIONS"/>
                    </columns>
                </TableView>

                <Label fx:id="infoLabel" styleClass="muted-label login-info"/>
            </children>
            <padding>
                <Insets top="26" right="28" bottom="32" left="28"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
