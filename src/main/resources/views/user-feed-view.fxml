<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.UserFeedController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <HBox spacing="20" styleClass="content-layer page">
            <children>
                <VBox spacing="24" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="12" styleClass="hero-card">
                            <children>
                                <Label text="ACTUALITE GAMING" styleClass="hero-title"/>
                                <Label text="Suis les equipes actives, les annonces de recrutement et les temps forts de la plateforme." styleClass="muted-label"/>
                                <HBox spacing="12">
                                    <children>
                                        <Label fx:id="equipesCountLabel" styleClass="chip-active"/>
                                        <Label fx:id="recrutementsCountLabel" styleClass="chip-active"/>
                                        <Label text="Compte user" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="16" styleClass="coord-card">
                            <children>
                                <Label text="Partager une actualite" styleClass="section-title"/>
                                <TextArea fx:id="postArea" prefRowCount="3" promptText="Ecris un message ou partage une idee..." styleClass="text-area"/>
                                <HBox spacing="12">
                                    <children>
                                        <Label text="Tournois" styleClass="chip-active"/>
                                        <Label text="Recrutement" styleClass="chip-active"/>
                                        <Label text="Boutique" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                                <Button onAction="#onPublish" text="Publier" styleClass="classic-button"/>
                            </children>
                        </VBox>
                        <VBox fx:id="postsContainer" spacing="12" HBox.hgrow="ALWAYS"/>
                    </children>
                </VBox>
                <VBox prefWidth="280" spacing="12">
                    <children>
                        <Label text="A surveiller" styleClass="section-title"/>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#recrutement" styleClass="card-title"/>
                                <Label text="Equipes ouvertes" styleClass="muted-label"/>
                            </children>
                        </VBox>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#tournois" styleClass="card-title"/>
                                <Label text="Calendrier esport" styleClass="muted-label"/>
                            </children>
                        </VBox>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#gaming" styleClass="card-title"/>
                                <Label text="Nouveautes materiel" styleClass="muted-label"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </HBox>
    </content>
</ScrollPane>
