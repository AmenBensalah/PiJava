<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17.0.2-ea"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.esportify.controllers.TeamDashboardController"
           styleClass="team-dashboard-overlay-root">
    <children>
        <ScrollPane fx:id="dashboardScrollPane" fitToWidth="true" styleClass="page-scroll team-dashboard-scroll">
            <content>
                <VBox spacing="22" styleClass="content-layer page team-dashboard-page">
                    <children>
                        <HBox spacing="12" styleClass="team-status-banner">
                            <children>
                                <Label text="●" styleClass="team-status-banner-icon"/>
                                <Label fx:id="teamStatusBannerLabel" text="Equipe creee et selectionnee comme votre equipe." styleClass="team-status-banner-text"/>
                            </children>
                        </HBox>

                        <HBox spacing="20" styleClass="hero-card">
                            <children>
                                <ImageView fx:id="teamImageView" fitWidth="300" fitHeight="210" preserveRatio="false" styleClass="detail-logo"/>
                                <VBox spacing="14" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox spacing="10">
                                            <children>
                                                <Label fx:id="tagChipLabel" styleClass="chip-active"/>
                                                <Label fx:id="regionChipLabel" styleClass="chip-active"/>
                                                <Label fx:id="classementChipLabel" styleClass="chip-active"/>
                                                <Label fx:id="visibiliteChipLabel" styleClass="chip-active"/>
                                            </children>
                                        </HBox>
                                        <Label fx:id="teamNameLabel" styleClass="hero-title"/>
                                        <Label fx:id="teamDescriptionLabel" wrapText="true" styleClass="muted-label"/>
                                        <HBox spacing="14">
                                            <children>
                                                <Button fx:id="editTeamButton" onAction="#onEditTeam" text="Gerer l'equipe" styleClass="manager-action-button"/>
                                                <Button fx:id="manageCandidatesButton" onAction="#onManageCandidates" text="Gerer demandes" styleClass="manager-action-button"/>
                                                <Button fx:id="deleteTeamButton" onAction="#onDeleteTeam" text="Supprimer l'equipe" styleClass="manager-delete-button"/>
                                                <Button fx:id="backToHubButton" onAction="#onBackToTeams" text="Retour au hub" styleClass="manager-outline-button"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <GridPane hgap="18" vgap="18" styleClass="team-dashboard-stats-grid">
                            <children>
                                <VBox spacing="8" styleClass="summary-card team-dashboard-kpi" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label fx:id="membersCountLabel" styleClass="summary-value team-dashboard-kpi-value"/>
                                        <Label text="MEMBRES" styleClass="card-title team-dashboard-kpi-label"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8" styleClass="summary-card team-dashboard-kpi" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label fx:id="recruitmentCountLabel" styleClass="summary-value team-dashboard-kpi-value"/>
                                        <Label text="RECRUTEMENTS" styleClass="card-title team-dashboard-kpi-label"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8" styleClass="summary-card team-dashboard-kpi" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Label fx:id="regionStatLabel" styleClass="summary-value team-dashboard-kpi-value"/>
                                        <Label text="REGION" styleClass="card-title team-dashboard-kpi-label"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8" styleClass="summary-card team-dashboard-kpi" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                    <children>
                                        <Label fx:id="creationDateLabel" styleClass="summary-value team-dashboard-kpi-value"/>
                                        <Label text="CREATION" styleClass="card-title team-dashboard-kpi-label"/>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <VBox spacing="12" styleClass="coord-card team-dashboard-card">
                            <children>
                                <Label text="Coordonnees equipe" styleClass="section-title team-dashboard-section-title"/>
                                <Label text="Acces Discord pour les membres et le manager." styleClass="muted-label team-dashboard-section-subtitle"/>
                                <VBox spacing="12" styleClass="team-dashboard-discord-card">
                                    <children>
                                        <Label text="SERVEUR DISCORD" styleClass="field-label team-dashboard-legend"/>
                                        <Label fx:id="discordLinkLabel" wrapText="true" styleClass="card-title team-dashboard-discord-text"/>
                                        <Button fx:id="editDiscordButton" onAction="#onEditDiscordLink" text="Modifier le lien" styleClass="classic-button team-dashboard-link-button"/>
                                        <Label text="GESTION DU LIEN" styleClass="field-label team-dashboard-inline-tag"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="16" styleClass="coord-card team-dashboard-card team-dashboard-ai-shell">
                            <children>
                                <Label text="Statistiques IA" styleClass="section-title team-dashboard-ai-title"/>
                                <Label text="Analyse basee sur les candidatures acceptees, le recrutement, la performance et l'activite recente." styleClass="muted-label team-dashboard-ai-subtitle"/>
                                <VBox fx:id="aiRolesContainer" spacing="16"/>
                            </children>
                        </VBox>

                        <VBox spacing="12" styleClass="coord-card team-dashboard-card">
                            <children>
                                <Label text="Recrutements" styleClass="section-title team-dashboard-section-title"/>
                                <VBox fx:id="recrutementsContainer" spacing="10"/>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card team-dashboard-card">
                            <children>
                                <Label text="Membres actifs" styleClass="section-title team-dashboard-section-title"/>
                                <VBox fx:id="activeMembersContainer" spacing="10"/>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card team-dashboard-card">
                            <children>
                                <Label text="Candidatures recues" styleClass="section-title team-dashboard-section-title"/>
                                <HBox spacing="12">
                                    <children>
                                        <Button fx:id="analyseIaButton" onAction="#onAnalyseCandidaturesIa" text="Analyse IA" styleClass="manager-action-button team-dashboard-main-action"/>
                                        <Label fx:id="candidatureAiInfoLabel" wrapText="true" styleClass="muted-label"/>
                                    </children>
                                </HBox>
                                <VBox fx:id="candidaturesContainer" spacing="10"/>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets top="24" right="24" bottom="120" left="24"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>

        <VBox fx:id="chatPanel"
              spacing="0"
              visible="false"
              managed="false"
              styleClass="coord-card team-dashboard-card team-chat-shell team-chat-floating-panel"
              StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets top="0" right="20" bottom="96" left="20"/>
            </StackPane.margin>
            <children>
                <HBox spacing="14" styleClass="team-chat-header">
                    <children>
                        <VBox spacing="2">
                            <children>
                                <Label text="Discussion d'equipe" styleClass="section-title team-chat-title"/>
                                <Label text="Salon reserve au roster pour s'organiser et echanger." styleClass="muted-label team-chat-status"/>
                            </children>
                        </VBox>
                        <Label HBox.hgrow="ALWAYS"/>
                        <Button onAction="#onCloseChat" text="X" styleClass="team-chat-close-button"/>
                    </children>
                </HBox>
                <ScrollPane fx:id="discussionScrollPane"
                            fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            styleClass="page-scroll team-chat-messages-shell"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="discussionMessagesContainer" spacing="10" styleClass="team-chat-messages-content" VBox.vgrow="ALWAYS"/>
                    </content>
                </ScrollPane>
                <HBox spacing="12" styleClass="team-chat-input-bar">
                    <children>
                        <TextArea fx:id="discussionInputArea" prefRowCount="3" promptText="Ecrire un message a l'equipe..." styleClass="text-area admin-editor-area team-dashboard-chat-input team-chat-input-field" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="sendDiscussionButton" onAction="#onSendDiscussionMessage" text="Envoyer" styleClass="team-chat-send-button"/>
                    </children>
                </HBox>
                <Label fx:id="discussionInfoLabel" wrapText="true" styleClass="muted-label team-chat-footer-info"/>
            </children>
        </VBox>

        <Button fx:id="chatToggleButton"
                onAction="#onToggleChat"
                text="💬"
                styleClass="team-chat-fab team-chat-fab-closed"
                StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets top="0" right="24" bottom="24" left="0"/>
            </StackPane.margin>
        </Button>
    </children>
</StackPane>
