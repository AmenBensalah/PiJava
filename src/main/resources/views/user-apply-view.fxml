<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.UserApplyController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <HBox spacing="20" styleClass="content-layer page">
            <children>
                <VBox spacing="18" styleClass="coord-card form-shell" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="heroTitleLabel" styleClass="hero-title"/>
                        <Label text="Complete le formulaire pour rejoindre cette equipe." styleClass="muted-label"/>
                        <Label text="Pseudo" styleClass="field-label"/>
                        <TextField fx:id="pseudoField" styleClass="field"/>
                        <HBox spacing="14">
                            <children>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Niveau" styleClass="field-label"/>
                                        <ComboBox fx:id="niveauBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Role prefere" styleClass="field-label"/>
                                        <ComboBox fx:id="roleBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox spacing="14">
                            <children>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Region" styleClass="field-label"/>
                                        <ComboBox fx:id="regionBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Disponibilite" styleClass="field-label"/>
                                        <ComboBox fx:id="disponibiliteBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Label text="Motivation" styleClass="field-label"/>
                        <TextArea fx:id="motivationArea" prefRowCount="8" promptText="Explique ton experience, ton objectif et pourquoi tu veux rejoindre cette equipe." styleClass="text-area"/>
                        <Label fx:id="infoLabel" wrapText="true" styleClass="muted-label"/>
                        <HBox spacing="14">
                            <children>
                                <Button onAction="#onSubmit" text="Envoyer candidature" styleClass="manager-action-button"/>
                                <Button onAction="#onCancel" text="Annuler" styleClass="manager-outline-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox prefWidth="320" spacing="14" styleClass="coord-card">
                    <children>
                        <ImageView fx:id="previewImageView" fitWidth="280" fitHeight="190" preserveRatio="false" styleClass="detail-logo"/>
                        <Label fx:id="previewTagLabel" styleClass="chip-active"/>
                        <Label text="Apercu equipe" styleClass="section-title"/>
                        <Label fx:id="previewDescriptionLabel" wrapText="true" styleClass="muted-label"/>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </HBox>
    </content>
</ScrollPane>
