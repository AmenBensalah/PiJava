<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.CandidateManagementController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="24" styleClass="content-layer page">
            <children>
                <VBox spacing="16" styleClass="hero-card">
                    <children>
                        <Label text="Gestion des candidats" styleClass="hero-title"/>
                        <Label fx:id="subtitleLabel" styleClass="muted-label"/>
                    </children>
                </VBox>
                <VBox spacing="16" styleClass="coord-card">
                    <children>
                        <Label text="Candidats" styleClass="section-title"/>
                        <Label fx:id="emptyLabel" text="Aucune candidature pour le moment." styleClass="muted-label"/>
                        <TableView fx:id="candidatureTable" visible="false" managed="false" prefHeight="420" styleClass="manager-table">
                            <columns>
                                <TableColumn fx:id="pseudoColumn" text="Pseudo" prefWidth="140"/>
                                <TableColumn fx:id="niveauColumn" text="Niveau" prefWidth="120"/>
                                <TableColumn fx:id="disponibiliteColumn" text="Disponibilite" prefWidth="140"/>
                                <TableColumn fx:id="statutColumn" text="Statut" prefWidth="120"/>
                                <TableColumn fx:id="actionColumn" text="Actions" prefWidth="420"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
                <Button onAction="#onBack" text="Retour equipe" styleClass="classic-button"/>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
