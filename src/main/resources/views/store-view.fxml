<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.StoreController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page">
            <children>
                <VBox spacing="14" styleClass="hero-card">
                    <children>
                        <Label text="BOUTIQUE PREMIUM" styleClass="hero-title"/>
                        <Label text="Equipe-toi avec le meilleur materiel officiel Esportify." styleClass="muted-label"/>
                        <HBox spacing="12">
                            <children>
                                <Label text="Tous" styleClass="chip-active"/>
                                <Label text="Carte mere" styleClass="chip-active"/>
                                <Label text="Clavier" styleClass="chip-active"/>
                                <Label text="PC gamer" styleClass="chip-active"/>
                                <Label text="Souris" styleClass="chip-active"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <HBox spacing="18">
                    <children>
                        <VBox prefWidth="300" spacing="14" styleClass="coord-card">
                            <children>
                                <Label text="Recherche avancee" styleClass="section-title"/>
                                <Label text="Recherche" styleClass="field-label"/>
                                <TextField promptText="Nom du produit" styleClass="field"/>
                                <Label text="Categorie" styleClass="field-label"/>
                                <ComboBox promptText="Toutes" styleClass="dark-combo"/>
                                <HBox spacing="12">
                                    <children>
                                        <Button text="Rechercher" styleClass="classic-button"/>
                                        <Button text="Reinitialiser" styleClass="classic-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <ImageView fitWidth="210" fitHeight="210" preserveRatio="false">
                                    <image><Image url="@../images/logo3.png"/></image>
                                </ImageView>
                                <Label text="carte mere hyts" styleClass="section-title"/>
                                <Label text="100.00 €" styleClass="summary-value"/>
                                <Label text="EN STOCK" styleClass="chip-active"/>
                                <Button text="Voir details" styleClass="classic-button"/>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <ImageView fitWidth="210" fitHeight="210" preserveRatio="false">
                                    <image><Image url="@../images/logo5.png"/></image>
                                </ImageView>
                                <Label text="carte mere ttht1410" styleClass="section-title"/>
                                <Label text="140.00 €" styleClass="summary-value"/>
                                <Label text="EN STOCK" styleClass="chip-active"/>
                                <Button text="Voir details" styleClass="classic-button"/>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <ImageView fitWidth="210" fitHeight="210" preserveRatio="false">
                                    <image><Image url="@../images/logo3.png"/></image>
                                </ImageView>
                                <Label text="PC gamer mpla" styleClass="section-title"/>
                                <Label text="140.00 €" styleClass="summary-value"/>
                                <Label text="RUPTURE" styleClass="chip-active"/>
                                <Button text="Voir details" styleClass="classic-button"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
