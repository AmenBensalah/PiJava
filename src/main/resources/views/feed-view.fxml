<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.FeedController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <HBox spacing="20" styleClass="content-layer page">
            <children>
                <VBox spacing="24" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="12" styleClass="hero-card">
                            <children>
                                <Label text="FIL D'ACTUALITE" styleClass="hero-title"/>
                                <Label text="Publie des annonces, partage des videos et suis les tendances de la communaute E-sportify." styleClass="muted-label"/>
                                <HBox spacing="12">
                                    <children>
                                        <Label fx:id="equipesCountLabel" styleClass="chip-active"/>
                                        <Label fx:id="recrutementsCountLabel" styleClass="chip-active"/>
                                        <Label text="Logiciel premium" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="16" styleClass="coord-card">
                            <children>
                                <Label text="Vous" styleClass="section-title"/>
                                <TextArea fx:id="postArea" prefRowCount="3" promptText="Publier un message, une image ou un lien video..." styleClass="text-area"/>
                                <HBox spacing="12">
                                    <children>
                                        <Label text="Images/Videos/Jeux" styleClass="chip-active"/>
                                        <Label text="Lien video" styleClass="chip-active"/>
                                        <Label text="Event" styleClass="chip-active"/>
                                        <Label text="Hashtags IA" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                                <Button onAction="#onPublish" text="Publier" styleClass="classic-button"/>
                            </children>
                        </VBox>
                        <VBox fx:id="postsContainer" spacing="12" HBox.hgrow="ALWAYS"/>
                    </children>
                </VBox>
                <VBox prefWidth="280" spacing="12">
                    <children>
                        <Label text="Tendances" styleClass="section-title"/>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#sport" styleClass="card-title"/>
                                <Label text="8" styleClass="chip-active"/>
                                <Label text="Top hashtag" styleClass="muted-label"/>
                            </children>
                        </VBox>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#electronique" styleClass="card-title"/>
                                <Label text="5" styleClass="chip-active"/>
                                <Label text="Gaming tech" styleClass="muted-label"/>
                            </children>
                        </VBox>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#tournoi" styleClass="card-title"/>
                                <Label text="4" styleClass="chip-active"/>
                                <Label text="Scene esport" styleClass="muted-label"/>
                            </children>
                        </VBox>
                        <VBox spacing="10" styleClass="quick-list-card">
                            <children>
                                <Label text="#esportify" styleClass="card-title"/>
                                <Label text="6" styleClass="chip-active"/>
                                <Label text="Communaute" styleClass="muted-label"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </HBox>
    </content>
</ScrollPane>
