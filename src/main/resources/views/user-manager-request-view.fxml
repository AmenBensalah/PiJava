<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.UserManagerRequestController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="24" styleClass="content-layer page">
            <children>
                <VBox spacing="16" styleClass="hero-card">
                    <children>
                        <Label text="DEVENIR MANAGER" styleClass="hero-title"/>
                        <Label text="Propose ton profil manager et explique pourquoi tu veux prendre la direction d'une equipe." styleClass="muted-label"/>
                        <HBox spacing="12">
                            <children>
                                <Label text="Role leadership" styleClass="chip-active"/>
                                <Label text="Evaluation rapide" styleClass="chip-active"/>
                                <Label text="Style premium" styleClass="chip-active"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="22" styleClass="workspace-row">
                    <children>
                        <VBox fx:id="formShell" spacing="18" styleClass="coord-card form-shell" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <children>
                                        <Label text="Formulaire manager" styleClass="section-title"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="backButton" text="Retour" onAction="#onBack" styleClass="manager-outline-button"/>
                                        <Button fx:id="submitButton" text="Envoyer la demande" onAction="#onSubmit" styleClass="manager-action-button"/>
                                    </children>
                                </HBox>

                                <GridPane hgap="16" vgap="16" styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <children>
                                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <children>
                                                <Label text="Nom du joueur" styleClass="field-label"/>
                                                <TextField fx:id="usernameField" promptText="Nom du joueur" styleClass="field"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <children>
                                                <Label text="Niveau" styleClass="field-label"/>
                                                <ComboBox fx:id="levelBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <VBox spacing="10">
                                    <children>
                                        <Label text="Pourquoi veux-tu devenir manager ?" styleClass="field-label"/>
                                        <TextArea fx:id="motivationArea" prefRowCount="8" promptText="Explique ton experience, ta vision et ce que tu veux apporter a une equipe." styleClass="text-area"/>
                                    </children>
                                </VBox>

                                <Label fx:id="infoLabel" styleClass="muted-label login-info"/>
                            </children>
                        </VBox>

                        <VBox prefWidth="320" spacing="18" styleClass="dashboard-side-column">
                            <children>
                                <VBox spacing="16" styleClass="side-panel-card">
                                    <children>
                                        <Label text="Vision manager" styleClass="section-title"/>
                                        <ImageView fitWidth="286" fitHeight="170" preserveRatio="false">
                                            <image>
                                                <Image url="@../images/banner.png"/>
                                            </image>
                                        </ImageView>
                                        <VBox spacing="12" styleClass="quick-list-card">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="12">
                                                    <children>
                                                        <Label text="Guide" styleClass="chip-active"/>
                                                        <Label text="Decris ton style de leadership" styleClass="muted-label"/>
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" spacing="12">
                                                    <children>
                                                        <Label text="Guide" styleClass="chip-active"/>
                                                        <Label text="Choisis un niveau honnete" styleClass="muted-label"/>
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" spacing="12">
                                                    <children>
                                                        <Label text="Guide" styleClass="chip-active"/>
                                                        <Label text="Sois clair sur ton objectif manager" styleClass="muted-label"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
