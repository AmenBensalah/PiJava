<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.UserStoreController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="16" styleClass="content-layer page">
            <children>
                <HBox spacing="18" styleClass="hero-card">
                    <children>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="BOUTIQUE" styleClass="eyebrow"/>
                                <Label text="NOTRE CATALOGUE" styleClass="hero-title"/>
                                <Label text="Decouvrez nos produits gaming et e-sport." styleClass="card-title"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="10">
                            <children>
                                <Button text="IA Recommandations" onAction="#onShowRecommendations" styleClass="btn-secondary" prefWidth="145" prefHeight="38"/>
                                <Button text="Panier" onAction="#onOpenCart" styleClass="btn-secondary" prefWidth="90" prefHeight="38"/>
                                <Button text="Reinitialiser Filtres" onAction="#onReset" styleClass="btn-primary" prefWidth="150" prefHeight="38"/>
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets top="16" right="18" bottom="16" left="18"/>
                    </padding>
                </HBox>

                <HBox spacing="10">
                    <children>
                        <Button text="TOUS" onAction="#onShowAll" styleClass="cat-pill-active"/>
                        <Button text="DISPONIBLES" onAction="#onShowAvailableOnly" styleClass="cat-pill"/>
                        <Label text="PC GAMER" styleClass="cat-pill"/>
                        <Label text="CLAVIER" styleClass="cat-pill"/>
                        <Label text="CARTE MERE" styleClass="cat-pill"/>
                        <Label text="SOURIS" styleClass="cat-pill"/>
                    </children>
                </HBox>

                <VBox spacing="14" styleClass="coord-card">
                    <children>
                        <Label text="Trouver un produit &amp; Offres" styleClass="section-title"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Client fidele ?" style="-fx-text-fill: #ff42d0; -fx-font-weight: 800;"/>
                                <TextField fx:id="emailField" promptText="Entrez votre e-mail..." styleClass="field" prefWidth="250"/>
                                <Button text="Activer -10% sur tout" onAction="#onActivateOffer" styleClass="btn-secondary" prefHeight="36"/>
                            </children>
                        </HBox>
                        <HBox spacing="10" alignment="BOTTOM_LEFT" styleClass="team-search-grid">
                            <children>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="MOT CLE" styleClass="field-label"/>
                                        <TextField fx:id="nameField" promptText="Nom du produit..." styleClass="field"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8">
                                    <children>
                                        <Label text="CATEGORIE" styleClass="field-label"/>
                                        <ComboBox fx:id="stockFilterBox" prefWidth="180" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                                <Button text="Prix +" onAction="#onSortPriceAsc" styleClass="cat-pill" prefWidth="82" prefHeight="38"/>
                                <Button text="Prix -" onAction="#onSortPriceDesc" styleClass="cat-pill" prefWidth="82" prefHeight="38"/>
                            </children>
                        </HBox>
                        <Label fx:id="resultsLabel" styleClass="muted-label"/>
                    </children>
                    <padding>
                        <Insets top="16" right="18" bottom="14" left="18"/>
                    </padding>
                </VBox>

                <FlowPane fx:id="productsContainer" hgap="16" vgap="16" prefWrapLength="930"/>
            </children>
            <padding>
                <Insets top="16" right="18" bottom="20" left="18"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
