<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.TournamentsController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page">
            <children>
                <VBox spacing="14" styleClass="hero-card">
                    <children>
                        <Label text="TOURNOIS" styleClass="hero-title"/>
                        <Label text="Cyber arena pour joueurs, squads et managers. Filtre, explore et rejoins les competitions." styleClass="muted-label"/>
                        <HBox spacing="12">
                            <children>
                                <Button text="Mes demandes" styleClass="classic-button"/>
                                <Button text="Voir le fil" styleClass="classic-button"/>
                                <Button text="Consulter jeux" styleClass="classic-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox spacing="14" styleClass="coord-card">
                    <children>
                        <Label text="Recherche avancee" styleClass="section-title"/>
                        <HBox spacing="14">
                            <children>
                                <VBox spacing="8">
                                    <children>
                                        <Label text="Game" styleClass="field-label"/>
                                        <TextField promptText="Valorant, CS2, Chess" styleClass="field"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8">
                                    <children>
                                        <Label text="Type de jeu" styleClass="field-label"/>
                                        <ComboBox promptText="Tous" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8">
                                    <children>
                                        <Label text="Type de tournoi" styleClass="field-label"/>
                                        <ComboBox promptText="Tous" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                                <VBox spacing="8">
                                    <children>
                                        <Label text="Statut" styleClass="field-label"/>
                                        <ComboBox promptText="Tous" styleClass="dark-combo"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <HBox spacing="18">
                    <children>
                        <VBox spacing="12" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Valorant Masters" styleClass="section-title"/>
                                <HBox spacing="10">
                                    <children>
                                        <Label text="FPS" styleClass="chip-active"/>
                                        <Label text="SOLO" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                                <Label text="GAME  Valorant" styleClass="muted-label"/>
                                <Label text="STATUT  Termine" styleClass="muted-label"/>
                                <Label text="PLACES  6 / 8" styleClass="muted-label"/>
                                <Label text="PRIZE  $600" styleClass="muted-label"/>
                                <Button text="Voir" styleClass="classic-button"/>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Fifa Arena" styleClass="section-title"/>
                                <HBox spacing="10">
                                    <children>
                                        <Label text="Sports" styleClass="chip-active"/>
                                        <Label text="SOLO" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                                <Label text="GAME  Fifa" styleClass="muted-label"/>
                                <Label text="STATUT  Termine" styleClass="muted-label"/>
                                <Label text="PLACES  10 / 12" styleClass="muted-label"/>
                                <Label text="PRIZE  $500" styleClass="muted-label"/>
                                <Button text="Voir" styleClass="classic-button"/>
                            </children>
                        </VBox>
                        <VBox spacing="12" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Chess Mind Cup" styleClass="section-title"/>
                                <HBox spacing="10">
                                    <children>
                                        <Label text="Mind" styleClass="chip-active"/>
                                        <Label text="SOLO" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                                <Label text="GAME  Chess" styleClass="muted-label"/>
                                <Label text="STATUT  Termine" styleClass="muted-label"/>
                                <Label text="PLACES  4 / 6" styleClass="muted-label"/>
                                <Label text="PRIZE  $800" styleClass="muted-label"/>
                                <Button text="Voir" styleClass="classic-button"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
