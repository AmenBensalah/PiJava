<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.UserTeamDetailController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page">
            <children>
                <HBox spacing="20" styleClass="hero-card">
                    <children>
                        <ImageView fx:id="teamImageView" fitWidth="300" fitHeight="210" preserveRatio="false" styleClass="detail-logo"/>
                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox spacing="10">
                                    <children>
                                        <Label fx:id="tagChipLabel" styleClass="chip-active"/>
                                        <Label fx:id="regionChipLabel" styleClass="chip-active"/>
                                        <Label fx:id="classementChipLabel" styleClass="chip-active"/>
                                        <Label fx:id="visibiliteChipLabel" styleClass="chip-active"/>
                                    </children>
                                </HBox>
                                <Label fx:id="teamNameLabel" styleClass="hero-title"/>
                                <Label fx:id="teamDescriptionLabel" wrapText="true" styleClass="muted-label"/>
                                <HBox spacing="14">
                                    <children>
                                        <Button fx:id="applyButton" onAction="#onApply" text="Postuler" styleClass="manager-action-button"/>
                                        <Button fx:id="backButton" onAction="#onBack" text="Retour aux equipes" styleClass="manager-outline-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <HBox spacing="18">
                    <children>
                        <VBox spacing="8" styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="membersCountLabel" styleClass="summary-value"/>
                                <Label text="Membres" styleClass="card-title"/>
                            </children>
                        </VBox>
                        <VBox spacing="8" styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="recruitmentCountLabel" styleClass="summary-value"/>
                                <Label text="Offres actives" styleClass="card-title"/>
                            </children>
                        </VBox>
                        <VBox spacing="8" styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="regionStatLabel" styleClass="summary-value"/>
                                <Label text="Region" styleClass="card-title"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <HBox spacing="18">
                    <children>
                        <VBox spacing="14" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Informations" styleClass="section-title"/>
                                <Label text="Date de creation" styleClass="field-label"/>
                                <Label fx:id="creationDateLabel" styleClass="muted-label"/>
                                <Label text="Discord" styleClass="field-label"/>
                                <Button fx:id="discordButton" onAction="#onJoinDiscord" text="Rejoindre serveur Discord" styleClass="manager-action-button"/>
                            </children>
                        </VBox>
                        <VBox spacing="14" styleClass="coord-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Membres de l'equipe" styleClass="section-title"/>
                                <VBox fx:id="rosterContainer" spacing="10"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <VBox spacing="14" styleClass="coord-card">
                    <children>
                        <Label text="Demandes de recrutement" styleClass="section-title"/>
                        <VBox fx:id="recrutementsContainer" spacing="10"/>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
