<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.UserTournamentsController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page">
            <children>
                <VBox spacing="14" styleClass="hero-card">
                    <children>
                        <Label text="DECROCHE TON TOURNOI" styleClass="hero-title"/>
                        <Label text="Consulte les tournois, filtre rapidement et ouvre les details sans quitter cette interface." styleClass="muted-label"/>
                        <HBox spacing="14">
                            <children>
                                <TextField fx:id="nameField" promptText="Rechercher un tournoi..." HBox.hgrow="ALWAYS" styleClass="field"/>
                                <ComboBox fx:id="typeFilterBox" prefWidth="200" styleClass="dark-combo"/>
                                <Button text="Rafraichir" onAction="#onSearch" styleClass="classic-button"/>
                                <Button text="Reset filtres" onAction="#onReset" styleClass="manager-outline-button"/>
                            </children>
                        </HBox>
                        <Label fx:id="resultsLabel" styleClass="muted-label"/>
                    </children>
                </VBox>
                <VBox spacing="16" styleClass="coord-card team-search-card">
                    <children>
                        <Label text="Tournois disponibles" styleClass="section-title"/>
                        <FlowPane fx:id="tournamentsContainer" hgap="18" vgap="18" prefWrapLength="1100"/>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
