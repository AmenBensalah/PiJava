<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.esportify.controllers.AdminFeedController"
            fitToWidth="true"
            styleClass="page-scroll">
    <content>
        <VBox spacing="22" styleClass="content-layer page admin-reference-page">
            <children>
                <VBox spacing="12" styleClass="hero-card admin-reference-hero">
                    <children>
                        <Label text="FIL D'ACTUALITE" styleClass="admin-eyebrow"/>
                        <Label text="GESTION DES ANNONCES" styleClass="admin-reference-title"/>
                        <Label text="Creez et suivez les annonces du fil d'actualite." styleClass="admin-reference-subtitle" wrapText="true"/>
                        <HBox spacing="14">
                            <children>
                                <Button text="Creer une annonce" styleClass="admin-glow-button"/>
                                <Button text="Rafraichir" onAction="#onRefresh" styleClass="admin-ghost-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="14">
                    <children>
                        <Label fx:id="totalPublicationsLabel" text="Publications" styleClass="admin-filter-pill"/>
                        <Label fx:id="totalAnnouncementsLabel" text="Annonces" styleClass="admin-filter-pill is-active"/>
                        <Label fx:id="totalCommentsLabel" text="Commentaires" styleClass="admin-filter-pill"/>
                        <Label text="Centre IA" styleClass="admin-filter-pill"/>
                    </children>
                </HBox>

                <VBox spacing="16" styleClass="admin-search-shell">
                    <children>
                        <Label text="Recherche avancee" styleClass="admin-search-title"/>
                        <GridPane hgap="14" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="20"/>
                                <ColumnConstraints percentWidth="20"/>
                                <ColumnConstraints percentWidth="20"/>
                                <ColumnConstraints percentWidth="18"/>
                                <ColumnConstraints percentWidth="22"/>
                            </columnConstraints>
                            <children>
                                <TextField fx:id="searchField" promptText="Rechercher..." styleClass="field admin-search-field" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="dateFromField" promptText="jj/mm/aaaa" styleClass="field admin-search-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <TextField fx:id="dateToField" promptText="jj/mm/aaaa" styleClass="field admin-search-field" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="perPageBox" maxWidth="1.7976931348623157E308" styleClass="dark-combo admin-search-field" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                <HBox spacing="12" GridPane.columnIndex="4" GridPane.rowIndex="0">
                                    <children>
                                        <Button text="Rechercher" onAction="#onSearch" styleClass="admin-glow-button"/>
                                        <Button text="Reinitialiser" onAction="#onReset" styleClass="admin-ghost-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </GridPane>
                        <TilePane hgap="12" vgap="12">
                            <children>
                                <Label text="Date desc" styleClass="admin-sort-pill"/>
                                <Label text="Date asc" styleClass="admin-sort-pill"/>
                                <Label text="Titre A-Z" styleClass="admin-sort-pill"/>
                                <Label text="Titre Z-A" styleClass="admin-sort-pill"/>
                            </children>
                        </TilePane>
                    </children>
                </VBox>

                <TableView fx:id="postsTable" minHeight="460" styleClass="manager-table admin-reference-table">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="90" text="ID"/>
                        <TableColumn fx:id="tagColumn" prefWidth="180" text="TAG"/>
                        <TableColumn fx:id="titleColumn" prefWidth="420" text="TITRE"/>
                        <TableColumn fx:id="linkColumn" prefWidth="220" text="LIEN"/>
                        <TableColumn fx:id="createdColumn" prefWidth="180" text="CREATION"/>
                        <TableColumn fx:id="actionsColumn" prefWidth="280" text="ACTIONS"/>
                    </columns>
                </TableView>
            </children>
            <padding>
                <Insets top="26" right="28" bottom="32" left="28"/>
            </padding>
        </VBox>
    </content>
</ScrollPane>
