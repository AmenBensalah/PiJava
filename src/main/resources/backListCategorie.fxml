<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-pane" stylesheets="@ajoutProduit.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.projetJava.controllers.BackListCategorieController" prefWidth="1280.0" prefHeight="720.0">
    
        <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="top-navbar" BorderPane.alignment="CENTER">
            <padding><Insets left="20.0" right="30.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="logo-text" text="E-" />
                    <Label styleClass="logo-text, logo-white" text="SPORTIFY" />
                    <Label style="-fx-text-fill: #ffa500; -fx-background-color: #332100; -fx-padding: 3 8; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 10px;" text="ADMIN" translateX="10" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField prefWidth="350.0" promptText="Rechercher joueurs, equipes, tournois..." styleClass="global-search" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="15.0" alignment="CENTER">
                    <Button onAction="#goToAdminProduit" text="Dashboard" styleClass="btn-primary" />
                    <Button onAction="#handleViewProfile" text="Voir mon profil" styleClass="btn-secondary" />
                </HBox>
            </children>
        </HBox>
    </top>

        <left>
        <VBox prefWidth="220.0" styleClass="global-sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Menu">
                    <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToFrontOffice" styleClass="menu-btn" text="Client (Front)" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToNewsFeed" styleClass="menu-btn" text="Gestion fil d'actualite" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToTeamsAdmin" styleClass="menu-btn" text="Gestion equipes" />
                <VBox>
                    <Button maxWidth="1.7976931348623157E308" text="Gestion des equipes" styleClass="sidebar-submenu-btn" onAction="#goToTeamsAdmin" />
                    <Button maxWidth="1.7976931348623157E308" text="Gestion demande manager" styleClass="sidebar-submenu-btn" onAction="#goToManagerRequestsAdmin" />
                </VBox>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Gestion tournoi" />
                <VBox>
                    <Button maxWidth="1.7976931348623157E308" text="Tournois" styleClass="sidebar-submenu-btn" onAction="#goToTournoisAdmin" />
                    <Button maxWidth="1.7976931348623157E308" text="Participations" styleClass="sidebar-submenu-btn" onAction="#goToParticipationsAdmin" />
                </VBox>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Gestion boutique" />
                <VBox>
                    <Button maxWidth="1.7976931348623157E308" text="Centre de mailing" styleClass="sidebar-submenu-btn" onAction="#goToMailing" />
                    <Button maxWidth="1.7976931348623157E308" text="Produits" styleClass="sidebar-submenu-btn" onAction="#goToAdminProduit" />
                    <Button maxWidth="1.7976931348623157E308" text="Categories" styleClass="sidebar-submenu-btn, sidebar-submenu-active" />
                    <Button maxWidth="1.7976931348623157E308" text="Paiements" styleClass="sidebar-submenu-btn" onAction="#goToPayments" />
                    <Button maxWidth="1.7976931348623157E308" text="Prediction CA" styleClass="sidebar-submenu-btn" onAction="#goToRevenuePrediction" />
                    <Button maxWidth="1.7976931348623157E308" text="Commandes" styleClass="sidebar-submenu-btn" onAction="#goToCommandes" />
                </VBox>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToGestionComptes" styleClass="menu-btn" text="Gestion comptes" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="1.7976931348623157E308" onAction="#handleLogout" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Deconnexion" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll-pane">
            <content>
                <VBox spacing="25.0" styleClass="main-area-bg" minHeight="1000">
                    <padding><Insets bottom="40.0" left="50.0" right="50.0" top="30.0" /></padding>
                    <children>
                        <HBox prefHeight="140.0" styleClass="boutique-banner" alignment="CENTER_LEFT">
                            <padding><Insets left="40.0" right="40.0" /></padding>
                            <children>
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label styleClass="banner-title" text="GESTION DES CATEGORIES" />
                                    <Label styleClass="banner-subtitle" text="Organisez vos produits avec style." />
                                </VBox>
                                <HBox spacing="15.0">
                                    <Button onAction="#goToFrontOffice" text="Boutique" styleClass="theme-toggle-btn" prefWidth="140" prefHeight="45" />
                                    <Button onAction="#goToCreateForm" text="+ Nouvelle categorie" styleClass="btn-3d-cyan" prefWidth="200" prefHeight="45" />
                                </HBox>
                            </children>
                        </HBox>

                        <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                            <!-- SECTION GAUCHE : TABLEAU -->
                            <VBox styleClass="filter-panel" HBox.hgrow="ALWAYS">
                                <HBox styleClass="table-header-row" spacing="10">
                                    <Label text="ID" prefWidth="50" styleClass="table-header-text" />
                                    <Label text="NOM" prefWidth="250" styleClass="table-header-text" />
                                    <Label text="NB PRODUITS" prefWidth="120" styleClass="table-header-text" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="ACTIONS" prefWidth="150" alignment="CENTER_RIGHT" styleClass="table-header-text" />
                                </HBox>
                                <VBox fx:id="tableContainer" />
                            </VBox>

                            <!-- SECTION DROITE : STATISTIQUES 3D -->
                            <VBox style="-fx-background-color: #151521; -fx-border-color: linear-gradient(to right, #00e5ff, #8a2be2); -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(138,43,226,0.5), 30, 0, 0, 0);" minWidth="400" prefWidth="450" alignment="TOP_CENTER" spacing="20">
                                <padding><Insets top="30" right="20" bottom="20" left="20"/></padding>
                                <Label text="REPARTITION DENSITE" style="-fx-text-fill: #00e5ff; -fx-font-size: 20px; -fx-font-weight: 900; -fx-font-family: 'Impact'; -fx-effect: dropshadow(one-pass-box, #00e5ff, 10, 0, 0, 0);" />
                                <Label text="Volume de produits par categorie" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
                                
                                <javafx.scene.chart.PieChart fx:id="statChart" prefHeight="400" style="-fx-pie-label-visible: true; -fx-legend-visible: false; -fx-cursor: hand;" />
                            </VBox>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>

