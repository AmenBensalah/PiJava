<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="920.0" prefWidth="1380.0" styleClass="login-root" stylesheets="@esportify/login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ProjetPI.controllers.RegisterController">
    <children>
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="arena-background" />
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="arena-overlay" />

        <HBox alignment="CENTER" fillHeight="false">
            <children>
                <VBox alignment="CENTER" maxWidth="560.0" prefWidth="560.0" spacing="18.0" styleClass="login-card register-card">
                    <padding>
                        <Insets bottom="34.0" left="42.0" right="42.0" top="28.0" />
                    </padding>

                    <Label styleClass="brand-badge" text="*" />
                    <Label styleClass="brand-name" text="E-SPORTIFY" />
                    <Label styleClass="screen-title" text="CREER UN COMPTE" />

                    <VBox spacing="14.0">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-pink" text="N" />
                                    <TextField fx:id="fullNameField" promptText="Nom complet" styleClass="login-input" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-pink" text="U" />
                                    <TextField fx:id="pseudoField" promptText="Pseudo" styleClass="login-input" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-pink" text="E" />
                                    <TextField fx:id="emailField" promptText="Email" styleClass="login-input" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-blue" text="P" />
                                    <PasswordField fx:id="passwordField" onAction="#handleRegister" promptText="Mot de passe" styleClass="login-input" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <Button maxWidth="1.7976931348623157E308" onAction="#handleRegister" styleClass="primary-login-button" text="CREER LE COMPTE" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleCaptureFaceId" styleClass="faceid-button" text="Capture Face ID" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#goToLogin" styleClass="faceid-button" text="Retour a la connexion" />

                    <Label fx:id="messageLabel" maxWidth="1.7976931348623157E308" styleClass="message login-message" wrapText="true" />
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
