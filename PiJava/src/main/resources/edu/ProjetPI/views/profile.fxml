<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="860.0" prefWidth="1380.0" styleClass="page-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ProjetPI.controllers.ProfileController">
    <children>
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="page-background" />
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="page-overlay" />

        <VBox alignment="CENTER" maxWidth="640.0" prefWidth="640.0" spacing="16.0" styleClass="page-card">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>

            <children>
                <Label fx:id="titleLabel" styleClass="title" text="Mon Profil" />
                <Label fx:id="roleLabel" styleClass="subtitle" text="Role:" />

                <TextField fx:id="fullNameField" promptText="Full name" />
                <TextField fx:id="pseudoField" promptText="Pseudo" />
                <TextField fx:id="emailField" promptText="Email" />
                <PasswordField fx:id="passwordField" promptText="New password (optional)" />

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button onAction="#handleUpdateProfile" text="Modifier" />
                        <Button onAction="#handleDeleteAccount" styleClass="danger-button" text="Supprimer Mon Compte" />
                        <Button onAction="#handleBack" styleClass="secondary-button" text="Retour" />
                    </children>
                </HBox>

                <Label fx:id="messageLabel" styleClass="message" wrapText="true" />
            </children>
        </VBox>
    </children>
</StackPane>
