<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="860.0" prefWidth="1380.0" styleClass="admin-root" stylesheets="@admin-dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ProjetPI.controllers.AdminDashboardController">
    <left>
        <VBox spacing="12.0" styleClass="sidebar">
            <padding>
                <Insets bottom="18.0" left="16.0" right="16.0" top="18.0" />
            </padding>
            <children>
                <Label styleClass="sidebar-brand" text="E-SPORTIFY" />
                <Label styleClass="sidebar-subtitle" text="Admin Dashboard" />
                <Label styleClass="sidebar-section" text="Administration" />
                <VBox spacing="12.0" styleClass="sidebar-group">
                    <children>
                        <Button maxWidth="1.7976931348623157E308" styleClass="sidebar-item, sidebar-item-active" text="Comptes" />
                        <Button maxWidth="1.7976931348623157E308" onAction="#handleViewProfile" styleClass="sidebar-item" text="Voir mon profil" />
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="1.7976931348623157E308" onAction="#handleLogout" styleClass="sidebar-logout" text="Deconnexion" />
                <Label fx:id="welcomeLabel" styleClass="welcome-text" text="Administrator" />
                <Label styleClass="sidebar-footer" text="Gestion des comptes" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="18.0" styleClass="content">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header-card">
                    <children>
                        <Label styleClass="header-title" text="Liste des comptes" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleOpenCreateDialog" styleClass="add-button" text="Ajouter compte" />
                        <Button onAction="#handleRefresh" styleClass="refresh-button" text="Actualiser" />
                    </children>
                </HBox>

                <VBox spacing="14.0" styleClass="table-card" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="filter-row">
                            <children>
                                <TextField fx:id="searchField" promptText="Rechercher (ID, nom, pseudo, email, role)" styleClass="search-field" HBox.hgrow="ALWAYS" />
                                <Label styleClass="filter-label" text="Trier par" />
                                <ComboBox fx:id="sortByCombo" prefWidth="180.0" styleClass="filter-combo" />
                                <Label styleClass="filter-label" text="Ordre" />
                                <ComboBox fx:id="sortDirectionCombo" prefWidth="140.0" styleClass="filter-combo" />
                                <Button onAction="#handleResetFilters" styleClass="reset-filter-button" text="Reinitialiser" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" styleClass="table-head-row">
                            <children>
                                <Label styleClass="section-title" text="Liste des comptes" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="totalCountLabel" styleClass="total-label" text="Total:0" />
                            </children>
                        </HBox>

                        <VBox styleClass="table-shell" VBox.vgrow="ALWAYS">
                            <children>
                                <TableView fx:id="userTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                                        <TableColumn fx:id="nameColumn" prefWidth="240.0" text="Nom" />
                                        <TableColumn fx:id="pseudoColumn" prefWidth="0.0" text="Pseudo" visible="false" />
                                        <TableColumn fx:id="emailColumn" prefWidth="300.0" text="Email" />
                                        <TableColumn fx:id="roleColumn" prefWidth="120.0" text="Role" />
                                        <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Statut" />
                                        <TableColumn fx:id="warnColumn" prefWidth="120.0" text="Avertissement" />
                                        <TableColumn fx:id="editColumn" prefWidth="120.0" text="Modifier" />
                                        <TableColumn fx:id="deleteColumn" prefWidth="120.0" text="Supprimer" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <Label fx:id="messageLabel" styleClass="message" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
