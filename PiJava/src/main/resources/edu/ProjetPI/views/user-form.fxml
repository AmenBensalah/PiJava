<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="860.0" prefWidth="1380.0" styleClass="page-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ProjetPI.controllers.UserFormController">
    <children>
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="page-background" />
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="page-overlay" />

        <VBox alignment="CENTER" maxWidth="700.0" prefWidth="700.0" spacing="14.0" styleClass="page-card">
            <padding>
                <Insets bottom="30.0" left="42.0" right="42.0" top="30.0" />
            </padding>
            <children>
                <Label fx:id="formTitleLabel" styleClass="title" text="Ajouter compte" />
                <Label fx:id="formSubtitleLabel" styleClass="subtitle" text="Creer un nouveau compte utilisateur" />

                <TextField fx:id="fullNameField" promptText="Nom complet" />
                <TextField fx:id="pseudoField" promptText="Pseudo" />
                <TextField fx:id="emailField" promptText="Email" />
                <PasswordField fx:id="passwordField" promptText="Mot de passe" />
                <ComboBox fx:id="roleBox" />

                <Label fx:id="passwordHintLabel" styleClass="hint" text="Mot de passe requis pour un nouveau compte" />

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="saveButton" onAction="#handleSave" text="Creer le compte" />
                        <Button onAction="#handleCancel" styleClass="secondary-button" text="Retour" />
                    </children>
                </HBox>

                <Label fx:id="messageLabel" styleClass="message" wrapText="true" />
            </children>
        </VBox>
    </children>
</StackPane>
