<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="900.0" prefWidth="1380.0" styleClass="login-root" stylesheets="@esportify/login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ProjetPI.controllers.ForgotPasswordController">
    <children>
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="arena-background" />
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="arena-overlay" />

        <HBox alignment="CENTER" fillHeight="false">
            <children>
                <VBox alignment="CENTER" maxWidth="560.0" prefWidth="560.0" spacing="18.0" styleClass="login-card register-card">
                    <padding>
                        <Insets bottom="34.0" left="42.0" right="42.0" top="28.0" />
                    </padding>

                    <Label styleClass="brand-badge" text="*" />
                    <Label styleClass="brand-name" text="E-SPORTIFY" />
                    <Label styleClass="screen-title" text="RESET PASSWORD" />

                    <VBox spacing="14.0">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-pink" text="E" />
                                    <TextField fx:id="emailField" promptText="Email" styleClass="login-input" />
                                </children>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-blue" text="#" />
                                    <TextField fx:id="codeField" promptText="6-digit reset code" styleClass="login-input" />
                                </children>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-blue" text="P" />
                                    <PasswordField fx:id="newPasswordField" promptText="New password" styleClass="login-input" />
                                </children>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="input-shell">
                                <children>
                                    <Label styleClass="input-icon accent-blue" text="C" />
                                    <PasswordField fx:id="confirmPasswordField" onAction="#handleResetPassword" promptText="Confirm password" styleClass="login-input" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <Button maxWidth="1.7976931348623157E308" onAction="#handleSendCode" styleClass="faceid-button" text="Send code by email" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleResetPassword" styleClass="primary-login-button" text="Reset password" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#goToLogin" styleClass="faceid-button" text="Back to login" />

                    <Label fx:id="messageLabel" maxWidth="1.7976931348623157E308" styleClass="message login-message" wrapText="true" />
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
