<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="860.0" prefWidth="1380.0" styleClass="root-pane"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.ProjetPI.controllers.AdminDashboardController">
    <stylesheets>
        <URL value="@/ajoutProduit.css" />
        <URL value="@/styles/esportify-theme.css" />
        <URL value="@admin-dashboard.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" styleClass="top-navbar" BorderPane.alignment="CENTER">
            <padding><Insets left="20.0" right="30.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="logo-text" text="E-" />
                    <Label styleClass="logo-text, logo-white" text="SPORTIFY" />
                    <Label style="-fx-text-fill: #ffa500; -fx-background-color: #332100; -fx-padding: 3 8; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 10px;" text="ADMIN" translateX="10" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField prefWidth="350.0" promptText="Ã°Å¸â€Â Rechercher joueurs, ÃƒÂ©quipes, tournois..." styleClass="global-search" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="15.0" alignment="CENTER">
                    <Button onAction="#goToCatalogue" text="Dashboard" styleClass="btn-primary" />
                    <Button onAction="#handleViewProfile" text="Voir mon profil" styleClass="btn-secondary" />
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" styleClass="global-sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Menu">
                    <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToFrontOffice" styleClass="menu-btn" text="Client (Front)" textFill="#00e5ff" style="-fx-font-weight: bold;" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Gestion fil d'actualite" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Gestion Equipes" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Gestion Tournoi" />
                <VBox>
                    <Button maxWidth="1.7976931348623157E308" text="Tournoi" styleClass="sidebar-submenu-btn" onAction="#goToTournoisAdmin" />
                    <Button maxWidth="1.7976931348623157E308" text="Participations" styleClass="sidebar-submenu-btn" onAction="#goToParticipationsAdmin" />
                </VBox>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Gestion Boutique" />
                <VBox>
                    <Button maxWidth="1.7976931348623157E308" text="Centre de Mailing" styleClass="sidebar-submenu-btn" onAction="#goToMailing" />
                    <Button maxWidth="1.7976931348623157E308" text="Produits" styleClass="sidebar-submenu-btn" onAction="#goToCatalogue" />
                    <Button maxWidth="1.7976931348623157E308" text="Categories" styleClass="sidebar-submenu-btn" onAction="#goToAdminCategorie" />
                    <Button maxWidth="1.7976931348623157E308" text="Paiements" styleClass="sidebar-submenu-btn" onAction="#goToPayments" />
                    <Button maxWidth="1.7976931348623157E308" text="Prediction CA" styleClass="sidebar-submenu-btn" onAction="#goToRevenuePrediction" />
                    <Button maxWidth="1.7976931348623157E308" text="Commandes" styleClass="sidebar-submenu-btn" onAction="#goToCommandes" />
                </VBox>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn, sidebar-submenu-active" text="Gestion comptes" />

                <Region VBox.vgrow="ALWAYS" />
                <VBox alignment="CENTER" spacing="10">
                    <padding><Insets bottom="20.0" left="20" right="20"/></padding>
                    <Button mnemonicParsing="false" prefWidth="1.7976931348623157E308" styleClass="theme-toggle-btn" text="Theme" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleLogout" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Deconnexion" />
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll-pane">
            <content>
                <VBox spacing="18.0" styleClass="main-area-bg">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                    <children>
                        <HBox prefHeight="140.0" styleClass="boutique-banner" alignment="CENTER_LEFT">
                            <padding><Insets left="40.0" right="40.0" /></padding>
                            <children>
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-text-fill: #00e5ff; -fx-font-size: 11px; -fx-font-weight: bold;" text="ADMIN" />
                                    <Label styleClass="banner-title" text="GESTION DES COMPTES" />
                                    <Label styleClass="banner-subtitle" text="Gerez les utilisateurs, roles et statuts." />
                                </VBox>
                                <HBox spacing="15.0" alignment="CENTER_RIGHT">
                                    <Button onAction="#handleRefresh" styleClass="btn-secondary" text="Actualiser" prefHeight="45" />
                                    <Button onAction="#handleOpenCreateDialog" styleClass="btn-3d-cyan" text="+ Ajouter compte" prefHeight="45" />
                                </HBox>
                            </children>
                        </HBox>

                        <VBox spacing="14.0" styleClass="advanced-search-box" VBox.vgrow="NEVER">
                            <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>
                            <children>
                                <Label text="Recherche avancee" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <TextField fx:id="searchField" promptText="Rechercher (ID, nom, pseudo, email, role)" styleClass="search-field" HBox.hgrow="ALWAYS" />
                                        <Label styleClass="filter-label" text="Trier par" />
                                        <ComboBox fx:id="sortByCombo" prefWidth="180.0" styleClass="filter-combo" />
                                        <Label styleClass="filter-label" text="Ordre" />
                                        <ComboBox fx:id="sortDirectionCombo" prefWidth="140.0" styleClass="filter-combo" />
                                        <Button onAction="#handleResetFilters" styleClass="reset-filter-button" text="Reinitialiser" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="14.0" styleClass="table-card" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="table-head-row">
                                    <children>
                                        <Label styleClass="section-title" text="Liste des comptes" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="totalCountLabel" styleClass="total-label" text="Total:0" />
                                    </children>
                                </HBox>

                                <VBox styleClass="table-shell" VBox.vgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="userTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                                                <TableColumn fx:id="nameColumn" prefWidth="240.0" text="Nom" />
                                                <TableColumn fx:id="pseudoColumn" prefWidth="0.0" text="Pseudo" visible="false" />
                                                <TableColumn fx:id="emailColumn" prefWidth="300.0" text="Email" />
                                                <TableColumn fx:id="roleColumn" prefWidth="120.0" text="Role" />
                                                <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Statut" />
                                                <TableColumn fx:id="warnColumn" prefWidth="140.0" text="Avertissement" />
                                                <TableColumn fx:id="editColumn" prefWidth="120.0" text="Modifier" />
                                                <TableColumn fx:id="deleteColumn" prefWidth="120.0" text="Supprimer" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>

                                <Label fx:id="messageLabel" styleClass="message" wrapText="true" />
                                <Label fx:id="welcomeLabel" managed="false" styleClass="welcome-text" visible="false" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
