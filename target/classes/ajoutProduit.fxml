<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-pane" stylesheets="@ajoutProduit.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.projetJava.controllers.AjoutProduitController" prefWidth="1280.0" prefHeight="720.0">
    
    <!-- TOP NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" styleClass="top-navbar" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="logo-text" text="E-" />
                    <Label styleClass="logo-text, logo-white" text="SPORTIFY" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField prefWidth="300.0" promptText="Rechercher joueurs, équipes, tournois..." styleClass="global-search" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10.0" alignment="CENTER">
                    <Region prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #2a3143; -fx-background-radius: 15;" />
                    <Region prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #2a3143; -fx-background-radius: 15;" />
                    <Region prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #2a3143; -fx-background-radius: 15;" />
                </HBox>
            </children>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="200.0" styleClass="global-sidebar" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="TOP_CENTER" prefWidth="180.0" spacing="15.0" style="-fx-background-color: #0f121d;">
                    <padding><Insets top="30.0" /></padding>
                    <children>
                        <Button onAction="#goToAdmin" text="⚙️ Administration" style="-fx-background-color: transparent; -fx-text-fill: #00e5ff; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #00e5ff; -fx-border-radius: 5px; -fx-padding: 8 15;" />
                        <Region prefHeight="20.0" />
                    </children>
                </VBox>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="≡ Menu">
                    <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
                </Button>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Fil d'actualité" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Equipes" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Tournois" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn, menu-btn-active" text="Boutique" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="Commandes" />
                
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER">
                    <padding><Insets bottom="20.0" /></padding>
                    <Button mnemonicParsing="false" prefWidth="160.0" prefHeight="30.0" styleClass="theme-toggle-btn" />
                </HBox>
            </children>
        </VBox>
    </left>

    <!-- MAIN AREA (Arena Background Simulation) -->
    <center>
        <BorderPane styleClass="main-area-bg">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <top>
                <VBox spacing="15.0" BorderPane.alignment="CENTER">
                    <children>
                        <!-- Banner -->
                        <VBox prefHeight="80.0" styleClass="boutique-banner" alignment="CENTER_LEFT">
                            <padding><Insets left="30.0" top="15.0" bottom="15.0" /></padding>
                            <children>
                                <Label style="-fx-text-fill: #00e5ff; -fx-font-size: 10px; -fx-font-weight: bold;" text="BOUTIQUE" />
                                <Label styleClass="banner-title" text="BOUTIQUE PREMIUM" />
                                <Label styleClass="banner-subtitle" text="Équipez-vous avec le meilleur matériel officiel E-Sportify." />
                            </children>
                        </VBox>
                        
                        <!-- Navigation categories -->
                        <HBox fx:id="categoryPillsContainer" alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" styleClass="donnees-ia-btn" text="Données IA" />
                            </children>
                            <padding>
                                <Insets left="15.0" right="15.0" />
                            </padding>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <left>
                <VBox prefWidth="250.0" spacing="15.0" styleClass="filter-panel" BorderPane.alignment="TOP_LEFT">
                    <BorderPane.margin>
                        <Insets top="20.0" right="20.0" />
                    </BorderPane.margin>
                    <children>
                        <VBox spacing="10.0">
                            <children>
                                <Label styleClass="filter-label" text="🔍 RECHERCHER" />
                                <TextField fx:id="searchNom" onKeyReleased="#appliquerFiltres" promptText="Nom du produit..." styleClass="filter-input" prefHeight="40" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label styleClass="filter-label" text="⌨ CATÉGORIE (SELECT)" />
                                <ComboBox fx:id="searchCat" onAction="#appliquerFiltres" prefWidth="250.0" promptText="Toutes" styleClass="filter-input" style="-fx-border-color: #3b82f6;" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0">
                            <children>
                                <Label styleClass="filter-label" text="⚖️ TRIER PAR PRIX" />
                                <HBox spacing="10.0">
                                    <children>
                                        <Button onAction="#trierPrixCroissant" prefWidth="120.0" styleClass="btn-special-cyan" text="📈 Croissant" />
                                        <Button onAction="#trierPrixDecroissant" prefWidth="120.0" styleClass="btn-special-pink" text="📉 Décroissant" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox spacing="10.0">
                            <children>
                                <Button onAction="#appliquerFiltres" text="Rechercher" styleClass="btn-rechercher" prefHeight="40" prefWidth="120" />
                                <Button onAction="#chargerProduits" text="Réinitialiser" styleClass="btn-reinitialiser" prefHeight="40" prefWidth="120" />
                            </children>
                        </HBox>

                        <!-- Fin de la barre de recherche -->
                    </children>
                </VBox>
            </left>

            <center>
                <ScrollPane fitToWidth="true" styleClass="transparent-scroll-pane" BorderPane.alignment="CENTER">
                    <BorderPane.margin>
                        <Insets top="20.0" />
                    </BorderPane.margin>
                    <content>
                        <FlowPane fx:id="produitsContainer" hgap="20.0" vgap="20.0">
                            <children>
                                <!-- Les produits seront chargés dynamiquement ici par Java -->
                            </children>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>
