<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root" stylesheets="@ajoutProduit.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.projetJava.controllers.BackCategorieController" prefWidth="1280.0" prefHeight="720.0">
    
    <!-- TOP NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" styleClass="top-navbar" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label styleClass="logo-text" text="E-" />
                    <Label styleClass="logo-text, logo-white" text="SPORTIFY" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField prefWidth="300.0" promptText="Rechercher..." styleClass="global-search" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="200.0" styleClass="global-sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn" text="≡ Menu">
                    <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
                </Button>
                <!-- NAVIGATION BUTTONS -->
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToFrontOffice" styleClass="menu-btn" text="🌍 Client (Front)" textFill="#00e5ff" style="-fx-font-weight: bold;" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToAdminProduit" styleClass="menu-btn" text="📦 Admin Produit" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-btn, menu-btn-active" text="📂 Admin Catégorie" />
            </children>
        </VBox>
    </left>

    <!-- MAIN AREA -->
    <center>
        <BorderPane styleClass="main-area-bg">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <top>
                <!-- Banner & Advanced Stats -->
                <VBox spacing="15" BorderPane.alignment="CENTER">
                    <BorderPane.margin><Insets bottom="30.0"/></BorderPane.margin>
                    <HBox prefHeight="90.0" styleClass="boutique-banner" alignment="CENTER_LEFT">
                        <padding><Insets left="30.0" right="30.0" /></padding>
                        <children>
                            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: #00e5ff; -fx-font-size: 10px; -fx-font-weight: bold;" text="BACK-OFFICE_PROTOCOL: ACTIVE" />
                                <Label styleClass="banner-title" text="GESTION DES CATEGORIES" />
                                <Label styleClass="banner-subtitle" text="Interface Administrateur pour configurer les catégories des produits." />
                            </VBox>
                            
                            <!-- AI Dashboard Numbers -->
                            <HBox spacing="15" alignment="CENTER_RIGHT">
                                <VBox style="-fx-background-color: rgba(189, 0, 255, 0.1); -fx-padding: 5 15; -fx-background-radius: 8; -fx-border-color: rgba(189, 0, 255, 0.4); -fx-border-radius: 8;" alignment="CENTER">
                                    <Label text="INDEX_RATE" style="-fx-text-fill: #94a3b8; -fx-font-size: 9px;"/>
                                    <Label text="1.04ms" style="-fx-text-fill: #bd00ff; -fx-font-size: 16px; -fx-font-weight: 900;"/>
                                </VBox>
                                <VBox style="-fx-background-color: rgba(0, 229, 255, 0.1); -fx-padding: 5 15; -fx-background-radius: 8; -fx-border-color: rgba(0, 229, 255, 0.4); -fx-border-radius: 8;" alignment="CENTER">
                                    <Label text="INTEGRITY" style="-fx-text-fill: #94a3b8; -fx-font-size: 9px;"/>
                                    <Label text="100%" style="-fx-text-fill: #00e5ff; -fx-font-size: 16px; -fx-font-weight: 900;"/>
                                </VBox>
                                <Button text="[ FLUSH_CACHE ]" style="-fx-background-color: transparent; -fx-border-color: #ff0055; -fx-border-radius: 4; -fx-text-fill: #ff0055; -fx-font-weight: bold; -fx-font-size: 11px; -fx-cursor: hand; -fx-padding: 8 15;"/>
                            </HBox>
                        </children>
                    </HBox>
                </VBox>
            </top>

            <center>
                <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="filter-panel" BorderPane.alignment="CENTER" maxWidth="700">
                    <padding>
                        <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
                    </padding>
                    
                    <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Formulaire Catégorie" />

                    <GridPane alignment="CENTER" hgap="20.0" vgap="25.0">
                        <children>
                            <Label styleClass="filter-label" text="ID (AUTO-INCRÉMENT)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <TextField fx:id="tfId" promptText="Laissez vide pour l'Ajout. Requis pour Modif/Suppr." styleClass="filter-input" prefWidth="350" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <Label styleClass="filter-label" text="NOM" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <TextField fx:id="tfNom" promptText="Ex: Périphériques, Composants..." styleClass="filter-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        </children>
                    </GridPane>

                    <HBox alignment="CENTER" spacing="15.0">
                        <VBox.margin>
                            <Insets top="30.0" />
                        </VBox.margin>
                        <children>
                            <Button mnemonicParsing="false" onAction="#ajouterCategorie" styleClass="btn-3d-cyan" text="➕ Ajouter" prefWidth="150" prefHeight="40" style="-fx-font-size: 14px;" />
                            <Button mnemonicParsing="false" onAction="#modifierCategorie" styleClass="theme-toggle-btn" text="✏️ Modifier" textFill="WHITE" prefWidth="150" prefHeight="40" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
                            <Button mnemonicParsing="false" onAction="#supprimerCategorie" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;" text="🗑️ Supprimer" prefWidth="150" prefHeight="40" />
                        </children>
                    </HBox>
                </VBox>
            </center>
        </BorderPane>
    </center>
</BorderPane>
